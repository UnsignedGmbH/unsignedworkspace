---
// Brandwork Roadmap — abgeleitete Progress-View über die 7 Phasen.
// Wird in customer.astro & portal.astro eingehängt; Daten kommen über
// window.BWTimeline.render(getPct, onPick) — getPct(toolKey) → 0-100,
// onPick(toolKey) öffnet das passende Tool.
---

<section class="bw-tl mb-5">
  <div class="bw-tl-head">
    <span class="bw-tl-eyebrow">
      <span class="bw-tl-bar"></span>
      Brandwork Roadmap
    </span>
    <span id="bwTlAvg" class="bw-tl-avg">Ø 0%</span>
  </div>
  <div id="bwTlTrack" class="bw-tl-track" role="list"></div>
  <p class="bw-tl-foot">
    Sieben Phasen — vom ersten Briefing bis zum laufenden Drop. Klick auf eine Phase springt direkt ins passende Tool.
  </p>
</section>

<style>
  .bw-tl {
    background: linear-gradient(180deg, rgba(193, 48, 48, 0.05), transparent 70%);
    border: 0.5px solid var(--color-line);
    border-radius: 14px;
    padding: 14px 16px 14px;
  }
  .bw-tl-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
    margin-bottom: 14px;
  }
  .bw-tl-eyebrow {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 10px;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-ink);
  }
  .bw-tl-bar {
    width: 4px;
    height: 12px;
    background: var(--color-brand);
    border-radius: 2px;
    display: inline-block;
  }
  .bw-tl-avg {
    font-size: 11px;
    font-weight: 800;
    color: var(--color-brand);
    letter-spacing: 0.02em;
  }
  .bw-tl-track {
    position: relative;
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 4px;
    overflow-x: auto;
    padding: 4px 0 6px;
    scrollbar-width: none;
  }
  .bw-tl-track::-webkit-scrollbar { display: none; }
  .bw-tl-track::before {
    content: "";
    position: absolute;
    left: 7%;
    right: 7%;
    top: 25px;
    height: 2px;
    background: var(--color-line);
    z-index: 0;
  }
  .bw-tl-node {
    flex: 1 1 0;
    min-width: 84px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 5px;
    background: transparent;
    border: 0;
    cursor: pointer;
    padding: 0 2px 2px;
    font-family: inherit;
    -webkit-tap-highlight-color: transparent;
    color: inherit;
    z-index: 1;
    transition: transform 0.15s ease;
  }
  .bw-tl-node:hover:not(:disabled) { transform: translateY(-1px); }
  .bw-tl-node:disabled { cursor: default; opacity: 0.55; }
  .bw-tl-ring-wrap {
    position: relative;
    width: 42px;
    height: 42px;
    background: var(--color-card);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .bw-tl-ring {
    position: absolute;
    inset: 0;
    transform: rotate(-90deg);
    width: 100%;
    height: 100%;
  }
  .bw-tl-ring .ring-bg { stroke: var(--color-line); }
  .bw-tl-ring .ring-fg {
    stroke: var(--color-brand);
    transition: stroke-dashoffset 0.6s ease;
  }
  .bw-tl-node.is-complete .bw-tl-ring-wrap { background: var(--color-brand); }
  .bw-tl-node.is-complete .ring-bg { stroke: var(--color-brand); }
  .bw-tl-node.is-complete .bw-tl-num { color: #fff; }
  .bw-tl-num {
    font-size: 14px;
    font-weight: 900;
    font-style: italic;
    color: var(--color-ink);
    line-height: 1;
  }
  .bw-tl-node.is-soon .bw-tl-num { color: var(--color-ink-mute); }
  .bw-tl-label {
    font-size: 10px;
    font-weight: 700;
    color: var(--color-ink);
    text-align: center;
    line-height: 1.2;
    letter-spacing: 0.01em;
    max-width: 9em;
  }
  .bw-tl-pct {
    font-size: 10px;
    font-weight: 800;
    color: var(--color-brand);
    letter-spacing: 0.02em;
  }
  .bw-tl-node.is-soon .bw-tl-pct { color: var(--color-ink-mute); font-weight: 700; }
  .bw-tl-foot {
    margin-top: 10px;
    font-size: 10px;
    color: var(--color-ink-mute);
    line-height: 1.5;
  }

  @media (max-width: 640px) {
    .bw-tl-head { margin-bottom: 10px; }
    .bw-tl-track::before { left: 10%; right: 10%; }
    .bw-tl-node { min-width: 72px; }
    .bw-tl-label { font-size: 9px; }
    .bw-tl-foot { display: none; }
  }
</style>

<script is:inline>
  (function () {
    var PHASES = [
      { num: 1, label: "Branding", tool: "bi",
        sub: "Positionierung · Fundament" },
      { num: 2, label: "Design", tool: "design",
        sub: "Moodboard · Mockups · Kollektion" },
      { num: 3, label: "Produktion", tool: null,
        sub: "Techpack · Preise · Sampling", soon: true },
      { num: 4, label: "Shooting", tool: "sh",
        sub: "Moodboard · Ablauf · Styling" },
      { num: 5, label: "Shop", tool: "shop",
        sub: "Optimierung · Drop · Flats" },
      { num: 6, label: "Marketing", tool: "mk",
        sub: "Personal Brand · Ads · Flows" },
      { num: 7, label: "AI Guide", tool: "ai_guide",
        sub: "Wie · Planung · Moodboard" },
    ];

    var RING_CIRC = 2 * Math.PI * 17; // ≈ 106.81

    var built = false;
    var nodes = [];
    var lastOnPick = null;

    function svg(name, attrs) {
      var ns = "http://www.w3.org/2000/svg";
      var el = document.createElementNS(ns, name);
      Object.keys(attrs || {}).forEach(function (k) {
        el.setAttribute(k, attrs[k]);
      });
      return el;
    }

    function buildSkeleton(track) {
      track.textContent = "";
      nodes = [];
      PHASES.forEach(function (p) {
        var btn = document.createElement("button");
        btn.type = "button";
        btn.className = "bw-tl-node" + (p.soon ? " is-soon" : "");
        btn.setAttribute("role", "listitem");
        btn.title = p.label + " — " + p.sub + (p.soon ? " (kommt bald)" : "");

        var ring = document.createElement("div");
        ring.className = "bw-tl-ring-wrap";

        var s = svg("svg", { viewBox: "0 0 42 42", class: "bw-tl-ring" });
        var bg = svg("circle", {
          cx: "21", cy: "21", r: "17",
          class: "ring-bg", fill: "none", "stroke-width": "2.5",
        });
        var fg = svg("circle", {
          cx: "21", cy: "21", r: "17",
          class: "ring-fg", fill: "none", "stroke-width": "2.5",
          "stroke-linecap": "round",
          "stroke-dasharray": String(RING_CIRC) + " " + String(RING_CIRC),
          "stroke-dashoffset": String(RING_CIRC),
        });
        s.appendChild(bg);
        s.appendChild(fg);
        ring.appendChild(s);

        var num = document.createElement("span");
        num.className = "bw-tl-num";
        num.textContent = String(p.num);
        ring.appendChild(num);
        btn.appendChild(ring);

        var label = document.createElement("span");
        label.className = "bw-tl-label";
        label.textContent = p.label;
        btn.appendChild(label);

        var pctEl = document.createElement("span");
        pctEl.className = "bw-tl-pct";
        pctEl.textContent = p.soon ? "Bald" : "0%";
        btn.appendChild(pctEl);

        if (p.soon) {
          btn.disabled = true;
        } else {
          btn.addEventListener("click", function () {
            if (lastOnPick) lastOnPick(p.tool);
          });
        }

        track.appendChild(btn);
        nodes.push({ phase: p, btn: btn, fg: fg, pctEl: pctEl });
      });
      built = true;
    }

    function render(getPct, onPick) {
      var track = document.getElementById("bwTlTrack");
      var avgEl = document.getElementById("bwTlAvg");
      if (!track || !avgEl) return;
      lastOnPick = onPick || lastOnPick;
      if (!built) buildSkeleton(track);
      var sum = 0, counted = 0;
      nodes.forEach(function (n) {
        if (n.phase.soon) return;
        var pct = parseInt(getPct(n.phase.tool), 10) || 0;
        if (pct < 0) pct = 0;
        if (pct > 100) pct = 100;
        sum += pct;
        counted++;
        n.fg.setAttribute(
          "stroke-dashoffset",
          String(RING_CIRC * (1 - pct / 100))
        );
        n.pctEl.textContent = pct + "%";
        n.btn.classList.toggle("is-complete", pct >= 100);
        n.btn.classList.toggle("is-active", pct > 0 && pct < 100);
      });
      avgEl.textContent =
        "Ø " + Math.round(counted ? sum / counted : 0) + "%";
    }

    window.BWTimeline = { render: render };
  })();
</script>
