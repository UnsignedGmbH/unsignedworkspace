---
import AppLayout from "../layouts/AppLayout.astro";

// Tools nach BrandWork-Roadmap-Phasen sortiert
const tools = [
  // Phase 1: Branding
  { href: "/brand-identity", label: "Brand Identity", icon: "🪪", desc: "Logos · Farben · Vibe" },
  // Phase 2: Design
  { href: "/design", label: "Design", icon: "🎨", desc: "Layouts & Visuals" },
  { href: "/techpack", label: "Techpack", icon: "📐", desc: "Produktions-Specs pro Garment" },
  // Phase 3: Produktion
  { href: "/production", label: "Produktion", icon: "🏭", desc: "Kanban · Stages" },
  { href: "/calculator", label: "Kalkulator", icon: "💰", desc: "VK-Preis pro Piece" },
  // Phase 4: Shooting
  { href: "/shooting", label: "Shooting", icon: "📸", desc: "Checkliste · Moodboard" },
  { href: "/creator", label: "Creator Guide", icon: "📋", desc: "Briefings & Skripte" },
  // Phase 5: Shop
  { href: "/shop", label: "Shop", icon: "🛒", desc: "Shop · Drop-Planung" },
  // Phase 6: Marketing
  { href: "/marketing", label: "Marketing Plan", icon: "📈", desc: "Personal Brand · Ads" },
  { href: "/content", label: "Content", icon: "🎬", desc: "Strategie · Hooks · Videos" },
  { href: "/ads", label: "Ads", icon: "📈", desc: "Moodboard · 1:1 · 9:16" },
  { href: "/social", label: "Social Media", icon: "💬", desc: "Profile · Highlights · Captions" },
  // Phase 7: AI Guide
  { href: "/ai-guide", label: "Ai Guide", icon: "🤖", desc: "Moodboard & Prompts" },
];

const customerActions = [
  { href: "/customers", label: "Alle Kunden", icon: "👥" },
  { href: "/customers?new=1", label: "Neuer Kunde", icon: "➕" },
  { href: "/team", label: "Team", icon: "🧑‍💼" },
  { href: "/settings", label: "Einstellungen", icon: "⚙️" },
];
---

<AppLayout title="Dashboard" active="dashboard">
  <!-- ═══════ HERO ═══════ -->
  <section
    class="relative overflow-hidden rounded-2xl mb-5 md:mb-6 shadow-[0_10px_40px_rgba(0,0,0,0.08)]"
  >
    <!-- Background pattern -->
    <div
      class="absolute inset-0 bg-[#0a0a0a] bg-no-repeat bg-cover bg-center"
      style="background-image: url('/brand/hintergrund.jpg');"
      aria-hidden="true"
    >
    </div>
    <!-- Dark overlay for readability -->
    <div
      class="absolute inset-0 bg-gradient-to-br from-black/85 via-black/70 to-black/55"
      aria-hidden="true"
    >
    </div>

    <!-- Content -->
    <div class="relative px-5 md:px-8 py-6 md:py-8 text-white">
      <div class="flex items-start justify-between gap-4 flex-wrap">
        <div class="flex-1 min-w-0">
          <p
            id="heroGreeting"
            class="text-[11px] md:text-[12px] font-bold tracking-[0.18em] uppercase text-white/55"
          >
            Guten Tag
          </p>
          <h1
            class="font-display italic font-extrabold text-[36px] md:text-[56px] leading-[0.95] tracking-[-0.01em] mt-1 mb-2"
          >
            <span id="heroName">Workspace</span>
          </h1>
          <p class="text-[13px] md:text-[14px] text-white/65 max-w-[480px]">
            Hier läuft alles zusammen — Brand, Production, Marketing.
            Wähl ein Tool oder spring direkt zum Kunden.
          </p>
        </div>
        <!-- Wordmark logo (defaults to Unsigned, overridden via workspace/brand) -->
        <img
          id="heroWordmark"
          src="/brand/wordmark-light.png"
          alt="Unsigned"
          class="hidden sm:block h-[60px] md:h-[88px] w-auto opacity-90 shrink-0 select-none pointer-events-none"
          loading="lazy"
        />
      </div>

      <!-- Stats inline -->
      <div
        class="grid grid-cols-2 md:grid-cols-4 gap-2 md:gap-3 mt-5 md:mt-6"
      >
        <div
          class="bg-white/10 backdrop-blur-sm border border-white/10 rounded-[10px] px-3 md:px-4 py-3"
        >
          <div
            id="statActive"
            class="text-[20px] md:text-[26px] font-extrabold leading-none"
          >—</div>
          <div class="text-[10px] md:text-[11px] text-white/55 mt-1 font-medium">Aktive Kunden</div>
        </div>
        <div
          class="bg-white/10 backdrop-blur-sm border border-white/10 rounded-[10px] px-3 md:px-4 py-3"
        >
          <div
            id="statArchived"
            class="text-[20px] md:text-[26px] font-extrabold leading-none"
          >—</div>
          <div class="text-[10px] md:text-[11px] text-white/55 mt-1 font-medium">Archiviert</div>
        </div>
        <div
          class="bg-white/10 backdrop-blur-sm border border-white/10 rounded-[10px] px-3 md:px-4 py-3"
        >
          <div
            id="statOnline"
            class="text-[20px] md:text-[26px] font-extrabold leading-none text-[#9FE1CB]"
          >—</div>
          <div class="text-[10px] md:text-[11px] text-white/55 mt-1 font-medium">Team online</div>
        </div>
        <div
          class="bg-white/10 backdrop-blur-sm border border-white/10 rounded-[10px] px-3 md:px-4 py-3"
        >
          <div
            id="statTeam"
            class="text-[20px] md:text-[26px] font-extrabold leading-none"
          >—</div>
          <div class="text-[10px] md:text-[11px] text-white/55 mt-1 font-medium">Team gesamt</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════ QUICK-SEARCH (Kunden direkt anspringen) ═══════ -->
  <div class="relative mb-3 md:mb-4">
    <span
      class="absolute left-3 top-1/2 -translate-y-1/2 text-ink-mute text-[14px] pointer-events-none"
      aria-hidden="true">🔍</span>
    <input
      id="qsInput"
      type="search"
      placeholder="Kunde suchen — Name oder Raum-Code…  (Tipp: „/" zum Fokussieren)"
      class="block w-full text-[13px] font-semibold border-[1.5px] border-line rounded-lg pl-10 pr-3 py-[10px] outline-none text-ink bg-white focus:border-brand"
      autocomplete="off"
      spellcheck="false"
    />
    <div
      id="qsResults"
      class="hidden absolute top-full left-0 right-0 mt-1 bg-card border-[0.5px] border-line rounded-lg shadow-[0_8px_24px_rgba(0,0,0,0.10)] max-h-[320px] overflow-y-auto z-50"
      role="listbox"
    ></div>
  </div>

  <!-- ═══════ KUNDEN-ACTIONS (Quick chips) ═══════ -->
  <div class="flex gap-2 mb-5 md:mb-6 flex-wrap">
    {
      customerActions.map((q) => (
        <a
          href={q.href}
          class="inline-flex items-center gap-2 px-3 md:px-4 py-2 md:py-[10px] rounded-full bg-card border-[0.5px] border-line hover:border-brand-border hover:bg-brand-dim transition-colors no-underline text-[12px] font-bold text-ink"
        >
          <span class="text-[14px]">{q.icon}</span>
          <span>{q.label}</span>
        </a>
      ))
    }
  </div>

  <!-- ═══════ TOOLS-GRID ═══════ -->
  <h2
    class="text-[10px] font-bold tracking-[0.12em] uppercase text-ink-mute mb-[10px] flex items-center gap-2"
  >
    <span class="w-1 h-3 bg-brand rounded-sm"></span>
    Tools
  </h2>
  <section
    class="grid grid-cols-2 sm:grid-cols-3 gap-2 md:gap-3 mb-5 md:mb-6"
  >
    {
      tools.map((t) => (
        <a
          href={t.href}
          class="group bg-card border-[0.5px] border-line rounded-xl p-3 md:p-[14px] flex items-start gap-3 hover:border-brand-border hover:bg-brand-dim hover:shadow-[0_4px_16px_rgba(193,48,48,0.08)] transition-all no-underline min-w-0"
        >
          <span class="w-9 h-9 md:w-10 md:h-10 rounded-lg bg-brand-dim flex items-center justify-center text-[18px] md:text-[20px] shrink-0 group-hover:bg-brand group-hover:text-white transition-colors">
            {t.icon}
          </span>
          <div class="flex-1 min-w-0">
            <div class="text-[12px] md:text-[13px] font-extrabold text-ink truncate">
              {t.label}
            </div>
            <div class="text-[10px] md:text-[11px] text-ink-mute mt-[1px] truncate">
              {t.desc}
            </div>
          </div>
        </a>
      ))
    }
  </section>

  <!-- ═══════ ZULETZT AKTIV ═══════ -->
  <h2
    class="text-[10px] font-bold tracking-[0.12em] uppercase text-ink-mute mb-[10px] flex items-center gap-2"
  >
    <span class="w-1 h-3 bg-brand rounded-sm"></span>
    Zuletzt aktiv
  </h2>
  <div
    id="recentList"
    class="bg-card border-[0.5px] border-line rounded-xl px-4 py-2"
  >
    <p class="text-[12px] text-ink-mute py-3">Lade…</p>
  </div>
</AppLayout>

<script is:inline>
  (function () {
    var $ = function (id) { return document.getElementById(id); };
    var RECENT_N = 6;

    // Time-of-day greeting
    function greet() {
      var h = new Date().getHours();
      if (h < 5) return "Gute Nacht";
      if (h < 11) return "Guten Morgen";
      if (h < 17) return "Guten Tag";
      if (h < 22) return "Guten Abend";
      return "Gute Nacht";
    }
    var g = $("heroGreeting");
    if (g) g.textContent = greet();

    function start() {
      var ui = window.appUI;
      var me = window.ME;
      var nameEl = $("heroName");

      function setHeroName(raw) {
        if (!nameEl || !raw) return;
        // Capitalize first letter for friendlier look
        nameEl.textContent = raw.charAt(0).toUpperCase() + raw.slice(1);
      }

      // Initial: email-prefix fallback so it's never empty
      if (me) {
        var fallback = me.email ? me.email.split("@")[0] : (me.name || "Workspace");
        setHeroName(fallback);

        // Then live-subscribe to team/<uid>/name so renaming in Settings updates immediately
        if (me.uid) {
          window.fb.ref("team/" + me.uid + "/name").on("value", function (s) {
            var n = s.val();
            setHeroName((n && n.trim()) || fallback);
          });
        }
      }

      var renderRecent = ui.throttle(function (state) {
        var active = state.list.filter(function (c) { return !c.arch; });
        var archived = state.list.length - active.length;
        $("statActive").textContent = active.length;
        $("statArchived").textContent = archived;

        var recent = active.slice(0, RECENT_N);
        var list = $("recentList");
        if (!recent.length) {
          list.innerHTML =
            '<p class="text-[12px] text-ink-mute py-3">Noch keine Aktivität — leg deinen ersten Kunden an.</p>';
          return;
        }
        list.innerHTML = recent
          .map(function (c, i) {
            var nameSafe = ui.escapeHtml(c.name || "Unbenannt");
            var roomSafe = ui.escapeHtml(c.room || "");
            return (
              '<a href="/customer?id=' +
              encodeURIComponent(c.id) +
              '" class="flex items-center gap-3 py-[10px] no-underline group ' +
              (i < recent.length - 1 ? "border-b-[0.5px] border-line" : "") +
              '">' +
              '<span class="w-8 h-8 rounded-full bg-brand-dim text-brand text-[11px] font-bold flex items-center justify-center shrink-0">' +
              ui.escapeHtml(ui.initials(c.name)) +
              "</span>" +
              '<div class="flex-1 min-w-0">' +
              '<div class="text-[13px] font-bold text-ink group-hover:text-brand truncate">' +
              nameSafe +
              "</div>" +
              '<div class="text-[11px] text-ink-mute mt-[1px] truncate">Raum ' +
              roomSafe +
              " · " +
              ui.escapeHtml(ui.fmtAgo(c.lastActive || c.created)) +
              "</div>" +
              "</div>" +
              '<span class="text-[9px] font-bold px-[9px] py-[3px] rounded-full bg-[#E1F5EE] text-[#085041]">Aktiv</span>' +
              "</a>"
            );
          })
          .join("");
      }, 250);

      ui.subscribeCustomers(renderRecent);

      window.fb.ref("team").on("value", function (s) {
        $("statTeam").textContent = Object.keys(s.val() || {}).length;
      });
      window.fb.ref("presence").on("value", function (s) {
        var v = s.val() || {};
        var now = Date.now();
        $("statOnline").textContent = Object.keys(v).filter(function (k) {
          return window.appUI.isPresenceFresh(v[k], now);
        }).length;
      });

      // Workspace-Brand: swap the wordmark image if a custom logo is set
      window.fb.ref("workspace/brand/logo").on("value", function (s) {
        var src = s.val();
        var el = $("heroWordmark");
        if (!el) return;
        el.src = (src && typeof src === "string") ? src : "/brand/wordmark-light.png";
      });

      // ── Quick-Search: live-Filter mit Tastatur-Navigation, Direktsprung zu /customer ──
      var qsInput = $("qsInput");
      var qsResults = $("qsResults");
      var allCustomers = [];
      var qsMatches = [];
      var qsSelected = -1;

      function renderQs() {
        var query = (qsInput.value || "").trim().toLowerCase();
        while (qsResults.firstChild) qsResults.removeChild(qsResults.firstChild);
        if (!query) { qsResults.classList.add("hidden"); qsSelected = -1; return; }
        qsMatches = allCustomers.filter(function (c) {
          var hay = ((c.name || "") + " " + (c.room || "")).toLowerCase();
          return hay.indexOf(query) !== -1;
        }).slice(0, 8);
        qsResults.classList.remove("hidden");
        if (!qsMatches.length) {
          var em = document.createElement("div");
          em.className = "px-4 py-3 text-[12px] text-ink-mute";
          em.textContent = "Keine Treffer";
          qsResults.appendChild(em);
          // Link zur vollen Suche in /customers anbieten
          var fallback = document.createElement("a");
          fallback.href = "/customers?q=" + encodeURIComponent(qsInput.value);
          fallback.className = "block px-4 py-2 text-[11px] font-bold text-brand hover:bg-brand-dim border-t-[0.5px] border-line";
          fallback.textContent = "→ Trotzdem in der Kunden-Liste suchen";
          qsResults.appendChild(fallback);
          qsSelected = -1;
          return;
        }
        qsMatches.forEach(function (c, i) {
          var a = document.createElement("a");
          a.href = "/customer?id=" + encodeURIComponent(c.id);
          a.className = "flex items-center gap-3 px-3 py-2 text-[13px] no-underline text-ink hover:bg-brand-dim border-b-[0.5px] border-line last:border-b-0";
          a.dataset.idx = String(i);
          var av = document.createElement("span");
          av.className = "w-7 h-7 rounded-full bg-brand-dim text-brand text-[10px] font-bold flex items-center justify-center shrink-0";
          av.textContent = ui.initials(c.name);
          var meta = document.createElement("div");
          meta.className = "flex-1 min-w-0";
          var name = document.createElement("div");
          name.className = "font-bold truncate";
          name.textContent = c.name || "Unbenannt";
          var sub = document.createElement("div");
          sub.className = "text-[11px] text-ink-mute truncate";
          sub.textContent = "Raum " + (c.room || "—") + (c.arch ? " · archiviert" : "");
          meta.appendChild(name);
          meta.appendChild(sub);
          a.appendChild(av);
          a.appendChild(meta);
          // Hover = Auswahl synchron halten
          a.addEventListener("mouseenter", function () {
            qsSelected = i;
            highlightQs();
          });
          qsResults.appendChild(a);
        });
        qsSelected = 0;
        highlightQs();
      }
      function highlightQs() {
        Array.prototype.forEach.call(qsResults.children, function (el, i) {
          if (el.tagName !== "A") return;
          if (i === qsSelected) el.classList.add("bg-brand-dim");
          else el.classList.remove("bg-brand-dim");
        });
      }

      qsInput.addEventListener("input", renderQs);
      qsInput.addEventListener("focus", renderQs);
      qsInput.addEventListener("keydown", function (e) {
        if (e.key === "Escape") { qsInput.value = ""; renderQs(); qsInput.blur(); return; }
        if (!qsResults.classList.contains("hidden") && qsMatches.length) {
          if (e.key === "ArrowDown") {
            e.preventDefault();
            qsSelected = (qsSelected + 1) % qsMatches.length;
            highlightQs();
          } else if (e.key === "ArrowUp") {
            e.preventDefault();
            qsSelected = (qsSelected - 1 + qsMatches.length) % qsMatches.length;
            highlightQs();
          } else if (e.key === "Enter") {
            e.preventDefault();
            var pick = qsMatches[qsSelected] || qsMatches[0];
            if (pick) location.href = "/customer?id=" + encodeURIComponent(pick.id);
          }
        } else if (e.key === "Enter" && qsInput.value.trim()) {
          // Keine Live-Treffer: Fallback auf volle Suche
          location.href = "/customers?q=" + encodeURIComponent(qsInput.value.trim());
        }
      });
      // Klick außerhalb schließt die Dropdown-Liste
      document.addEventListener("click", function (e) {
        if (e.target !== qsInput && !qsResults.contains(e.target)) {
          qsResults.classList.add("hidden");
        }
      });
      // "/" als globaler Shortcut (außer wenn der User schon in einem Eingabefeld ist)
      document.addEventListener("keydown", function (e) {
        if (e.key === "/" && document.activeElement && document.activeElement.tagName !== "INPUT" && document.activeElement.tagName !== "TEXTAREA") {
          e.preventDefault();
          qsInput.focus();
          qsInput.select();
        }
      });

      // Customer-Liste live abonnieren — wir nutzen denselben Helper wie alle anderen Pages.
      ui.subscribeCustomers(function (state) {
        allCustomers = (state && state.list) || [];
        // Falls Suche aktiv ist, neu rendern (z.B. wenn Kunde gerade umbenannt wurde)
        if (qsInput.value.trim()) renderQs();
      });
    }
    window.appUI.onAuth(start);
  })();
</script>
