---
import AppLayout from "../layouts/AppLayout.astro";
---

<AppLayout title="Team" active="team">
  <div id="teamList" class="flex flex-col gap-2">
    <p class="text-[12px] text-ink-mute py-3 text-center">Lade Team…</p>
  </div>
</AppLayout>

<script is:inline>
  (function () {
    var listEl = document.getElementById("teamList");
    var members = {};
    var presence = {};

    function render() {
      var ui = window.appUI;
      var keys = Object.keys(members);
      if (!keys.length) {
        listEl.innerHTML =
          '<p class="text-[12px] text-ink-mute py-3 text-center">Noch keine Mitglieder.</p>';
        return;
      }
      listEl.innerHTML = keys
        .map(function (uid) {
          var m = members[uid] || {};
          var p = presence[uid] || {};
          var online = p && p.online;
          var isMe = window.ME && window.ME.uid === uid;
          var role = isMe ? "owner" : m.role || "member";
          var uidSafe = ui.escapeHtml(uid);
          return (
            '<div class="bg-card border-[0.5px] border-line rounded-[10px] px-4 py-[14px] flex items-center gap-[14px]" data-uid="' +
            uidSafe + '">' +
            '<span class="w-10 h-10 rounded-full text-white text-[13px] font-bold flex items-center justify-center shrink-0 ' +
            ui.colorFor(uid) +
            '">' +
            ui.escapeHtml(ui.initials(m.name || m.email)) +
            "</span>" +
            '<div class="flex-1 min-w-0">' +
            '<div class="text-[13px] font-bold text-ink truncate">' +
            ui.escapeHtml(m.name || m.email || "Unbekannt") +
            "</div>" +
            '<div class="text-[11px] text-ink-mute mt-[1px] truncate">' +
            ui.escapeHtml(m.email || "") +
            "</div>" +
            "</div>" +
            '<div class="flex items-center gap-1 text-[11px] text-ink-mute whitespace-nowrap">' +
            '<span class="w-2 h-2 rounded-full ' +
            (online ? "bg-success" : "bg-line") +
            '"></span>' +
            (online ? "Online" : "Offline") +
            "</div>" +
            '<span class="ml-3 text-[9px] font-bold px-[9px] py-[3px] rounded-full whitespace-nowrap ' +
            (role === "owner"
              ? "bg-[#fde8e8] text-[#A32D2D]"
              : "bg-[#E6F1FB] text-[#0C447C]") +
            '">' +
            (isMe ? "Du" : role === "owner" ? "Owner" : "Member") +
            "</span>" +
            (isMe
              ? ""
              : '<button type="button" data-act="remove" data-uid="' + uidSafe +
                '" class="ml-2 text-[14px] text-ink-mute hover:text-[#b00020] bg-transparent border-0 cursor-pointer px-2 py-1 rounded-md hover:bg-[#fde8e8]" title="Aus Team entfernen">🗑</button>') +
            "</div>"
          );
        })
        .join("");

      listEl.querySelectorAll('[data-act="remove"]').forEach(function (btn) {
        btn.addEventListener("click", function () {
          var uid = btn.dataset.uid;
          var m = members[uid] || {};
          ui.confirm({
            title: "Mitglied entfernen?",
            description:
              '„' + (m.name || m.email || uid) +
              '" wird aus team und presence gelöscht. Falls die Person sich erneut einloggt, wird ein neuer Eintrag automatisch angelegt.',
            okLabel: "Entfernen",
          }).then(function (ok) {
            if (!ok) return;
            Promise.all([
              window.fb.ref("team/" + uid).remove(),
              window.fb.ref("presence/" + uid).remove(),
            ])
              .then(function () { ui.toast("Mitglied entfernt ✓"); })
              .catch(function (e) { ui.toast("Fehler: " + (e.code || e.message)); });
          });
        });
      });
    }

    var renderThrottled = function () {
      if (renderThrottled._raf) return;
      renderThrottled._raf = requestAnimationFrame(function () {
        renderThrottled._raf = null;
        render();
      });
    };

    function start() {
      window.fb.ref("team").on("value", function (s) {
        members = s.val() || {};
        renderThrottled();
      });
      window.fb.ref("presence").on("value", function (s) {
        presence = s.val() || {};
        renderThrottled();
      });
    }
    window.appUI.onAuth(start);
  })();
</script>
