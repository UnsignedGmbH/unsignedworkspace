---
import AppLayout from "../layouts/AppLayout.astro";

const accentColors = [
  { hex: "#C13030", id: "red" },
  { hex: "#1D9E75", id: "green" },
  { hex: "#185FA5", id: "blue" },
  { hex: "#9A2424", id: "wine" },
  { hex: "#D67A1A", id: "orange" },
  { hex: "#5E2A8A", id: "purple" },
];

const notifications = [
  { key: "activity", label: "Neue Kunden-Aktivität", default: true },
  { key: "weekly", label: "Wöchentliches Briefing per Mail", default: false },
  { key: "mentions", label: "Team-Erwähnungen", default: true },
];
---

<AppLayout title="Einstellungen" active="settings">
  <style>
    .uw-set-h {
      width: 100%;
      display: flex;
      align-items: center;
      gap: 8px;
      background: transparent;
      border: 0;
      padding: 0;
      margin: 0 0 10px 0;
      cursor: pointer;
      text-align: left;
      color: inherit;
      font: inherit;
    }
    .uw-set-chev {
      display: inline-block;
      width: 10px;
      height: 10px;
      transition: transform 0.15s ease;
      color: var(--color-ink-mute, #999);
      flex-shrink: 0;
    }
    .uw-set[data-open="false"] .uw-set-chev { transform: rotate(-90deg); }
    .uw-set[data-open="false"] .uw-set-body { display: none; }
    .uw-set-body { animation: uwFade 0.18s ease both; }
    @keyframes uwFade { from { opacity: 0; transform: translateY(-2px); } to { opacity: 1; transform: none; } }
  </style>
  <div class="space-y-3 max-w-[640px]">
    <section class="uw-set" data-open="true">
      <button type="button" class="uw-set-h">
        <svg class="uw-set-chev" viewBox="0 0 10 10" fill="none"><path d="M2 4l3 3 3-3" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
        <h3 class="text-[12px] font-bold text-ink m-0">Profil</h3>
      </button>
      <div class="uw-set-body">
      <div class="bg-card border-[0.5px] border-line rounded-[9px] px-4 py-3 flex items-center gap-3">
        <div class="flex-1">
          <div class="text-[13px] font-semibold text-ink">E-Mail</div>
          <div id="settingsEmail" class="text-[11px] text-ink-mute mt-[1px]">
            …
          </div>
        </div>
      </div>
      <div class="bg-card border-[0.5px] border-line rounded-[9px] px-4 py-3 mt-[6px] flex items-center gap-3">
        <div class="flex-1">
          <div class="text-[13px] font-semibold text-ink">Anzeigename</div>
          <div id="settingsName" class="text-[11px] text-ink-mute mt-[1px]">
            …
          </div>
        </div>
        <button
          id="renameBtn"
          type="button"
          class="text-[11px] font-bold text-brand bg-transparent border-0 cursor-pointer"
          >Ändern</button
        >
      </div>
      </div>
    </section>

    <section class="uw-set" data-open="false">
      <button type="button" class="uw-set-h">
        <svg class="uw-set-chev" viewBox="0 0 10 10" fill="none"><path d="M2 4l3 3 3-3" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
        <h3 class="text-[12px] font-bold text-ink m-0">Erscheinungsbild</h3>
      </button>
      <div class="uw-set-body">
      <div class="bg-card border-[0.5px] border-line rounded-[9px] px-4 py-3">
        <div class="text-[13px] font-semibold text-ink">Akzentfarbe</div>
        <div class="text-[11px] text-ink-mute mt-[1px]">
          Wirkt nur lokal in deinem Browser.
        </div>
        <div id="accentRow" class="flex gap-[9px] flex-wrap mt-2">
          {
            accentColors.map((c) => (
              <button
                type="button"
                data-accent={c.hex}
                aria-label={`Akzentfarbe ${c.id}`}
                class="accent-sw w-[30px] h-[30px] rounded-full cursor-pointer border-[3px] border-transparent"
                style={`background:${c.hex}`}
              />
            ))
          }
        </div>
      </div>
      </div>
    </section>

    <section class="uw-set" data-open="false">
      <button type="button" class="uw-set-h">
        <svg class="uw-set-chev" viewBox="0 0 10 10" fill="none"><path d="M2 4l3 3 3-3" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
        <h3 class="text-[12px] font-bold text-ink m-0">Benachrichtigungen</h3>
      </button>
      <div class="uw-set-body">
      {
        notifications.map((row) => (
          <div class="bg-card border-[0.5px] border-line rounded-[9px] px-4 py-3 mb-[6px] flex items-center gap-3">
            <div class="flex-1 text-[13px] font-semibold text-ink">
              {row.label}
            </div>
            <button
              type="button"
              data-toggle={row.key}
              data-default={String(row.default)}
              class="toggle w-[38px] h-[22px] rounded-full p-[3px] cursor-pointer flex items-center shrink-0 bg-[#ddd] justify-start"
            >
              <span class="w-4 h-4 rounded-full bg-white block" />
            </button>
          </div>
        ))
      }
      </div>
    </section>

    <section id="brandSection" class="uw-set hidden" data-open="false">
      <button type="button" class="uw-set-h">
        <svg class="uw-set-chev" viewBox="0 0 10 10" fill="none"><path d="M2 4l3 3 3-3" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
        <span class="w-1 h-3 bg-brand rounded-sm shrink-0"></span>
        <h3 class="text-[12px] font-bold text-ink m-0">Workspace-Brand</h3>
      </button>
      <div class="uw-set-body">
      <p class="text-[11px] text-ink-mute mb-[10px]">
        Die Identity die deine Kunden im Portal sehen. Wirkt im Header und auf
        der Begrüßung. Nur Admins können bearbeiten.
      </p>

      <div class="bg-card border-[0.5px] border-line rounded-[9px] px-4 py-3 mb-[6px] flex items-center gap-3">
        <div class="flex-1">
          <label class="text-[10px] font-bold tracking-[0.12em] uppercase text-ink-mute block mb-1">
            Brand-Name
          </label>
          <input
            id="brandName"
            type="text"
            placeholder="z.B. Unsigned"
            maxlength="40"
            class="block w-full text-[14px] font-semibold border-[1.5px] border-line rounded-lg px-[12px] py-[9px] outline-none text-ink bg-white focus:border-brand"
          />
          <div class="text-[10px] text-ink-mute mt-1">Erscheint im Sidebar-Header und im Portal.</div>
        </div>
      </div>

      <div class="bg-card border-[0.5px] border-line rounded-[9px] px-4 py-3 mb-[6px] flex items-start gap-3">
        <div class="flex-1">
          <label class="text-[10px] font-bold tracking-[0.12em] uppercase text-ink-mute block mb-1">
            Logo / Wordmark
          </label>
          <div class="flex items-center gap-3">
            <div
              id="brandLogoPreview"
              class="w-[120px] h-[60px] rounded-lg bg-[#0a0a0a] flex items-center justify-center text-white/40 text-[10px] overflow-hidden"
            >
              kein Logo
            </div>
            <div class="flex flex-col gap-1">
              <label
                class="text-[11px] font-bold text-brand cursor-pointer"
                >📁 Hochladen
                <input
                  id="brandLogoInput"
                  type="file"
                  accept="image/*"
                  class="hidden"
                /></label
              >
              <button
                id="brandLogoClear"
                type="button"
                class="text-[10px] text-ink-mute hover:text-brand bg-transparent border-0 cursor-pointer text-left"
                >× entfernen</button
              >
            </div>
          </div>
          <div class="text-[10px] text-ink-mute mt-2">
            Wird hell auf dunklem Hintergrund angezeigt — nimm ein helles
            Logo (PNG mit transparentem Hintergrund am besten).
          </div>
        </div>
      </div>

      <div class="bg-card border-[0.5px] border-line rounded-[9px] px-4 py-3 mb-[6px]">
        <label class="text-[10px] font-bold tracking-[0.12em] uppercase text-ink-mute block mb-1">
          Begrüßungstext im Portal
        </label>
        <textarea
          id="brandWelcome"
          rows="3"
          maxlength="280"
          placeholder="Hier arbeiten wir gemeinsam an deiner Brand. Alles was du eingibst, sieht dein Team bei [Brand] live."
          class="block w-full text-[12px] border-[1.5px] border-line rounded-lg px-[12px] py-[9px] outline-none text-ink bg-white focus:border-brand resize-y"
        ></textarea>
        <div class="text-[10px] text-ink-mute mt-1">
          Erscheint unter dem Greeting auf der Portal-Landing.
        </div>
      </div>

      <div class="flex justify-end gap-2 mt-2">
        <span id="brandStatus" class="text-[11px] text-ink-mute self-center"></span>
        <button
          id="brandSaveBtn"
          type="button"
          class="text-[11px] font-bold text-white bg-brand hover:bg-brand-dark px-4 py-2 rounded-lg cursor-pointer border-0"
          >Speichern</button
        >
      </div>
      </div>
    </section>

    <section id="defaultsSection" class="uw-set hidden" data-open="false">
      <button type="button" class="uw-set-h">
        <svg class="uw-set-chev" viewBox="0 0 10 10" fill="none"><path d="M2 4l3 3 3-3" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
        <span class="w-1 h-3 bg-brand rounded-sm shrink-0"></span>
        <h3 class="text-[12px] font-bold text-ink m-0">Standard-Listen pro Tool</h3>
      </button>
      <div class="uw-set-body">
      <p class="text-[11px] text-ink-mute mb-[10px]">
        Diese Items siehst du als Default bei jedem neuen Kunden / neuen Produkt.
        Bestehende Kunden behalten ihre Daten — nur frische Räume nehmen die neuen Defaults.
      </p>

      <div class="bg-card border-[0.5px] border-line rounded-[9px] px-4 py-4">
        <div class="flex items-center justify-between mb-2">
          <h4 class="text-[12px] font-bold text-ink">📸 Shooting Check</h4>
          <span id="shDefaultsStatus" class="text-[10px] text-ink-mute"></span>
        </div>
        <p class="text-[10px] text-ink-mute mb-3">
          Eine Zeile = ein Listen-Eintrag. Leerzeilen werden ignoriert.
        </p>

        <div id="shDefaultsGrid" class="grid grid-cols-1 md:grid-cols-2 gap-3"></div>

        <div class="flex justify-end gap-2 mt-3">
          <button
            id="shDefaultsReset"
            type="button"
            class="text-[11px] text-ink-mute hover:text-brand bg-transparent border-0 cursor-pointer"
            >Auf Original zurücksetzen</button
          >
          <button
            id="shDefaultsSave"
            type="button"
            class="text-[11px] font-bold text-white bg-brand hover:bg-brand-dark px-3 py-2 rounded-lg cursor-pointer border-0"
            >Speichern</button
          >
        </div>
      </div>

      <div class="bg-card border-[0.5px] border-line rounded-[9px] px-4 py-4 mt-3">
        <div class="flex items-center justify-between mb-2">
          <h4 class="text-[12px] font-bold text-ink">📣 Creator Guide</h4>
          <span id="crDefaultsStatus" class="text-[10px] text-ink-mute"></span>
        </div>
        <p class="text-[10px] text-ink-mute mb-3">
          Pro Kategorie: Titel + optionaler Hook. Leere Zeilen werden ignoriert.
        </p>

        <div id="crDefaultsCats" class="space-y-3"></div>

        <div class="flex justify-end gap-2 mt-3">
          <button
            id="crDefaultsReset"
            type="button"
            class="text-[11px] text-ink-mute hover:text-brand bg-transparent border-0 cursor-pointer"
            >Auf Original zurücksetzen</button
          >
          <button
            id="crDefaultsSave"
            type="button"
            class="text-[11px] font-bold text-white bg-brand hover:bg-brand-dark px-3 py-2 rounded-lg cursor-pointer border-0"
            >Speichern</button
          >
        </div>
      </div>
    </section>

    <section id="adminSection" class="uw-set hidden" data-open="false">
      <button type="button" class="uw-set-h">
        <svg class="uw-set-chev" viewBox="0 0 10 10" fill="none"><path d="M2 4l3 3 3-3" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
        <h3 class="text-[12px] font-bold text-ink m-0">Admin-Rechte</h3>
      </button>
      <div class="uw-set-body">
      <div class="bg-card border-[0.5px] border-line rounded-[9px] px-4 py-3 flex items-center gap-3">
        <div class="flex-1">
          <div id="adminStatus" class="text-[13px] font-semibold text-ink">…</div>
          <div id="adminHint" class="text-[11px] text-ink-mute mt-[1px]"></div>
        </div>
        <button
          id="adminAddBtn"
          type="button"
          class="hidden text-[11px] font-bold text-white bg-brand hover:bg-brand-dark px-3 py-2 rounded-lg cursor-pointer border-0"
          >Mich als Admin eintragen</button
        >
      </div>
      </div>
    </section>

    <section class="uw-set" data-open="true">
      <button type="button" class="uw-set-h">
        <svg class="uw-set-chev" viewBox="0 0 10 10" fill="none"><path d="M2 4l3 3 3-3" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
        <h3 class="text-[12px] font-bold text-ink m-0">Konto</h3>
      </button>
      <div class="uw-set-body">
      <div class="bg-card border-[0.5px] border-line rounded-[9px] px-4 py-3 flex items-center gap-3">
        <div class="flex-1">
          <div class="text-[13px] font-semibold text-ink">Abmelden</div>
          <div class="text-[11px] text-ink-mute mt-[1px]">
            Du wirst auf den Login-Bildschirm zurückgeleitet.
          </div>
        </div>
        <button
          id="logoutBtn"
          type="button"
          class="text-[11px] font-bold text-[#A32D2D] cursor-pointer bg-transparent border-0"
          >Abmelden</button
        >
      </div>
      </div>
    </section>
  </div>
</AppLayout>

<script is:inline>
  (function () {
    var ACCENT_KEY = "uw.accent";
    var NOTIF_KEY = "uw.notif";
    var SET_OPEN_KEY = "uw.settings_open";

    // ── Collapsible sections ───────────────────────────────
    var openMap = {};
    try { openMap = JSON.parse(localStorage.getItem(SET_OPEN_KEY) || "{}") || {}; } catch (e) {}
    function sectionId(s, i) {
      return s.id || ("set" + i);
    }
    function persist() {
      try { localStorage.setItem(SET_OPEN_KEY, JSON.stringify(openMap)); } catch (e) {}
    }
    document.querySelectorAll("section.uw-set").forEach(function (s, i) {
      var id = sectionId(s, i);
      var btn = s.querySelector(".uw-set-h");
      if (id in openMap) s.dataset.open = openMap[id] ? "true" : "false";
      btn.setAttribute("aria-expanded", s.dataset.open);
      btn.addEventListener("click", function () {
        var open = s.dataset.open !== "true";
        s.dataset.open = open ? "true" : "false";
        btn.setAttribute("aria-expanded", String(open));
        openMap[id] = open;
        persist();
      });
    });

    function applyAccent(hex) {
      document.documentElement.style.setProperty("--color-brand", hex);
      document.querySelectorAll(".accent-sw").forEach(function (b) {
        b.classList.toggle("border-ink", b.dataset.accent === hex);
      });
    }
    function loadAccent() {
      var hex = localStorage.getItem(ACCENT_KEY) || "#C13030";
      applyAccent(hex);
    }
    function loadNotif() {
      var raw = localStorage.getItem(NOTIF_KEY);
      var saved = {};
      try { saved = raw ? JSON.parse(raw) : {}; } catch (e) {}
      document.querySelectorAll(".toggle").forEach(function (t) {
        var key = t.dataset.toggle;
        var on = key in saved ? saved[key] : t.dataset.default === "true";
        t.dataset.on = String(on);
        t.classList.toggle("bg-brand", on);
        t.classList.toggle("bg-[#ddd]", !on);
        t.classList.toggle("justify-end", on);
        t.classList.toggle("justify-start", !on);
      });
    }
    function saveNotif() {
      var out = {};
      document.querySelectorAll(".toggle").forEach(function (t) {
        out[t.dataset.toggle] = t.dataset.on === "true";
      });
      localStorage.setItem(NOTIF_KEY, JSON.stringify(out));
    }

    document.querySelectorAll(".accent-sw").forEach(function (b) {
      b.addEventListener("click", function () {
        var hex = b.dataset.accent;
        localStorage.setItem(ACCENT_KEY, hex);
        applyAccent(hex);
        window.appUI && window.appUI.toast("Akzentfarbe gespeichert");
      });
    });
    document.querySelectorAll(".toggle").forEach(function (t) {
      t.addEventListener("click", function () {
        var on = t.dataset.on === "true";
        t.dataset.on = String(!on);
        t.classList.toggle("bg-brand", !on);
        t.classList.toggle("bg-[#ddd]", on);
        t.classList.toggle("justify-end", !on);
        t.classList.toggle("justify-start", on);
        saveNotif();
      });
    });
    loadAccent();
    loadNotif();

    function syncProfile(me) {
      var emailEl = document.getElementById("settingsEmail");
      var nameEl = document.getElementById("settingsName");
      if (emailEl && me && me.email) emailEl.textContent = me.email;
      if (!nameEl || !me) return;
      window.fb
        .ref("team/" + me.uid + "/name")
        .once("value")
        .then(function (s) {
          nameEl.textContent = s.val() || me.name || "—";
        });
    }
    window.appUI.onAuth(syncProfile);

    document.getElementById("renameBtn").addEventListener("click", function () {
      var nameEl = document.getElementById("settingsName");
      window.appUI
        .prompt({
          title: "Anzeigename ändern",
          value: nameEl.textContent || "",
          placeholder: "Vorname Nachname",
          okLabel: "Speichern",
        })
        .then(function (val) {
          if (!val || !val.trim() || !window.ME) return;
          window.fb
            .ref("team/" + window.ME.uid + "/name")
            .set(val.trim())
            .then(function () {
              nameEl.textContent = val.trim();
              window.appUI.toast("Name gespeichert");
            });
        });
    });

    document.getElementById("logoutBtn").addEventListener("click", function () {
      window.appUI.logout();
    });

    // ── Admin-Bootstrap ──────────────────────────────────────
    function initAdminUi(me) {
      if (!me || !me.uid) return;
      var section = document.getElementById("adminSection");
      var statusEl = document.getElementById("adminStatus");
      var hintEl = document.getElementById("adminHint");
      var addBtn = document.getElementById("adminAddBtn");
      if (!section) return;

      window.fb.ref("admins").on("value", function (s) {
        var admins = s.val() || {};
        var keys = Object.keys(admins);
        var iAmAdmin = !!admins[me.uid];
        var noAdminsYet = keys.length === 0;
        section.classList.remove("hidden");
        if (iAmAdmin) {
          statusEl.textContent = "✓ Du bist Admin";
          hintEl.textContent =
            "Du kannst Team-Mitglieder entfernen und Kunden überschreiben. Aktuell " +
            keys.length + " Admin" + (keys.length === 1 ? "" : "s") + ".";
          addBtn.classList.add("hidden");
        } else if (noAdminsYet) {
          statusEl.textContent = "Kein Admin gesetzt";
          hintEl.textContent =
            "Solange noch niemand Admin ist, kannst du dich als ersten eintragen. Danach können nur Admins weitere Admins hinzufügen.";
          addBtn.classList.remove("hidden");
        } else {
          statusEl.textContent = "Du bist kein Admin";
          hintEl.textContent =
            "Bitte einen bestehenden Admin (" +
            keys.length + " aktiv) dich als Admin einzutragen.";
          addBtn.classList.add("hidden");
        }
      }, function (err) {
        // If the read fails (e.g. rules not yet updated), show a hint
        section.classList.remove("hidden");
        statusEl.textContent = "Rules nicht aktiv";
        hintEl.textContent =
          "Bitte zuerst die Firebase-Rules aktualisieren (siehe Anleitung).";
      });

      addBtn.addEventListener("click", function () {
        window.fb.ref("admins/" + me.uid).set(true)
          .then(function () { window.appUI.toast("Du bist jetzt Admin ✓"); })
          .catch(function (e) {
            window.appUI.toast("Fehler: " + (e.code || e.message));
          });
      });
    }
    window.appUI.onAuth(initAdminUi);

    // ── Workspace-Brand ──────────────────────────────────────
    function initBrandUi(me) {
      if (!me || !me.uid) return;
      var section = document.getElementById("brandSection");
      var nameEl = document.getElementById("brandName");
      var welcomeEl = document.getElementById("brandWelcome");
      var preview = document.getElementById("brandLogoPreview");
      var fileInput = document.getElementById("brandLogoInput");
      var clearBtn = document.getElementById("brandLogoClear");
      var saveBtn = document.getElementById("brandSaveBtn");
      var statusEl = document.getElementById("brandStatus");
      if (!section) return;

      var brandLogoData = "";
      var isAdmin = false;

      function showLogo(src) {
        brandLogoData = src || "";
        preview.innerHTML = "";
        if (src) {
          var img = document.createElement("img");
          img.src = src;
          img.style.cssText = "max-width:100%;max-height:100%;object-fit:contain";
          preview.appendChild(img);
        } else {
          preview.textContent = "kein Logo";
        }
      }

      function setReadOnly(ro) {
        nameEl.disabled = ro;
        welcomeEl.disabled = ro;
        fileInput.disabled = ro;
        clearBtn.disabled = ro;
        saveBtn.disabled = ro;
        saveBtn.style.opacity = ro ? "0.4" : "";
        saveBtn.style.cursor = ro ? "not-allowed" : "pointer";
      }

      // Show section once admin status is known
      window.fb.ref("admins/" + me.uid).on("value", function (s) {
        isAdmin = !!s.val();
        section.classList.remove("hidden");
        setReadOnly(!isAdmin);
        statusEl.textContent = isAdmin ? "" : "Nur lesen — du bist kein Admin.";
      });

      // Load current brand
      window.fb.ref("workspace/brand").on("value", function (s) {
        var b = s.val() || {};
        if (document.activeElement !== nameEl) nameEl.value = b.name || "";
        if (document.activeElement !== welcomeEl) welcomeEl.value = b.welcome || "";
        showLogo(b.logo || "");
      }, function (err) {
        statusEl.textContent = "Lese-Fehler: " + (err.code || err.message);
      });

      // Compress + read uploaded file
      fileInput.addEventListener("change", function (e) {
        var f = e.target.files[0];
        if (!f) return;
        var reader = new FileReader();
        reader.onload = function (ev) {
          var img = new Image();
          img.onload = function () {
            var maxW = 600;
            var w = img.width, h = img.height;
            if (w > maxW) { h = Math.round(h * maxW / w); w = maxW; }
            var c = document.createElement("canvas");
            c.width = w; c.height = h;
            c.getContext("2d").drawImage(img, 0, 0, w, h);
            // Try PNG to preserve transparency
            showLogo(c.toDataURL("image/png"));
          };
          img.src = ev.target.result;
        };
        reader.readAsDataURL(f);
        e.target.value = "";
      });

      clearBtn.addEventListener("click", function () { showLogo(""); });

      saveBtn.addEventListener("click", function () {
        if (!isAdmin) return;
        statusEl.textContent = "Speichert…";
        var data = {
          name: nameEl.value.trim(),
          welcome: welcomeEl.value.trim(),
          logo: brandLogoData,
          updatedAt: window.fb.ts(),
          updatedBy: me.uid,
        };
        window.fb.ref("workspace/brand").set(data)
          .then(function () {
            statusEl.textContent = "✓ gespeichert";
            window.appUI.toast("Workspace-Brand gespeichert");
            setTimeout(function () { statusEl.textContent = ""; }, 2200);
          })
          .catch(function (err) {
            statusEl.textContent = "Fehler: " + (err.code || err.message);
            window.appUI.toast("Fehler: " + (err.code || err.message));
          });
      });
    }
    window.appUI.onAuth(initBrandUi);

    // ── Tool-Defaults: Shooting Check ──────────────────────
    var SH_CATS = [
      { key: "location",  label: "Pflicht-Content pro Location" },
      { key: "laydown",   label: "Produktbilder / Laydown" },
      { key: "model",     label: "Bilder am Model" },
      { key: "ads",       label: "Ads / Feed Content" },
      { key: "posen",     label: "Posen" },
      { key: "acc",       label: "Accessoires" },
      { key: "check",     label: "Letzter Check" },
    ];
    var SH_HARDCODED = {
      location: ["Produkt solo — Bilder","Produkt solo — Videos","Erst weiter zur nächsten Location wenn alles abgehakt ist"],
      laydown: ["Oberteil einzeln auf dem Boden","Hose einzeln auf dem Boden","Komplettes Set auf dem Boden","Detailbilder von Stoff, Logo, Print, Stick, Zip, Taschen, Bündchen, Nähten","Langsame Produktvideos / Pan-Shots"],
      model: ["Ganzkörper frontal","Ganzkörper seitlich","Ganzkörper von hinten","Halbnahe Shots vom Oberteil","Hose komplett sichtbar","Getragene Detailbilder von Oberteil und Hose","Nahshots von Stoff, Bündchen, Taschen, Zip, Print oder Stick","Videos frontal, seitlich, hinten und Details in Bewegung"],
      ads: ["Hero-Shots mit Attitude","Cleane Ganzkörperbilder","Laufbilder / Bewegungsshots","Stehende Street-Posen","Sitzende Posen auf Kante / Treppe / Bordstein","Bilder mit Platz für Text — Newsletter oder Ads","Enge Crop-Shots für Creatives","Hochformatbilder für Feed / Story / Reel Cover","Kurze Reel-Clips 3–5 Sekunden","Längere Clips 5–10 Sekunden","Ruhige Produktclips und aggressive Street-Clips"],
      posen: ["Frontal stehen","Seitlich stehen","Blick in Kamera","Blick weg von Kamera","Hände in Taschen","An Wand lehnen","Sitzen","Laufen","Über Schulter schauen"],
      acc: ["Cap / Beanie","Crossbody Bag / Shoulder Bag","Ketten, Ringe, Armband, Uhr","Sonnenbrille / Kopfhörer","Passende Sneaker — Option 1","Zweite Schuhoption","Fusselrolle, Klammern, Sicherheitsnadeln","Powerbank, Ladegerät, Spiegel"],
      check: ["Genug Ganzkörperbilder da","Genug Detailbilder da","Genug Hochformat da","Genug Videos da","Alles scharf gecheckt"],
    };

    function initShDefaults(me) {
      if (!me || !me.uid) return;
      var section = document.getElementById("defaultsSection");
      var grid = document.getElementById("shDefaultsGrid");
      var status = document.getElementById("shDefaultsStatus");
      var saveBtn = document.getElementById("shDefaultsSave");
      var resetBtn = document.getElementById("shDefaultsReset");
      if (!section || !grid) return;

      var isAdmin = false;

      function buildEditors(values) {
        grid.innerHTML = "";
        SH_CATS.forEach(function (c) {
          var fld = document.createElement("div");
          fld.innerHTML =
            '<label class="text-[10px] font-bold tracking-[0.12em] uppercase text-ink-mute block mb-1">' +
            c.label + '</label>' +
            '<textarea data-cat="' + c.key + '" rows="6" ' +
            'class="block w-full text-[12px] border-[1.5px] border-line rounded-lg px-[10px] py-[8px] outline-none text-ink bg-white focus:border-brand resize-y font-[ui-monospace] leading-[1.5]"></textarea>';
          grid.appendChild(fld);
          var ta = fld.querySelector("textarea");
          ta.value = ((values && values[c.key]) || SH_HARDCODED[c.key] || []).join("\n");
        });
      }

      function setEnabled(en) {
        grid.querySelectorAll("textarea").forEach(function (t) { t.disabled = !en; });
        saveBtn.disabled = !en;
        resetBtn.disabled = !en;
        saveBtn.style.opacity = en ? "" : "0.4";
        saveBtn.style.cursor = en ? "pointer" : "not-allowed";
        resetBtn.style.opacity = en ? "" : "0.4";
        resetBtn.style.cursor = en ? "pointer" : "not-allowed";
      }

      // Show section once admin status is known
      window.fb.ref("admins/" + me.uid).on("value", function (s) {
        isAdmin = !!s.val();
        section.classList.remove("hidden");
        setEnabled(isAdmin);
        if (!isAdmin) status.textContent = "nur lesen — du bist kein Admin";
      });

      // Load current defaults
      window.fb.ref("workspace/defaults/sh").on("value", function (s) {
        // Don't blow away in-progress edits if focus is in this section
        var ae = document.activeElement;
        if (ae && ae.dataset && ae.dataset.cat) return;
        buildEditors(s.val());
      }, function (err) {
        status.textContent = "Lese-Fehler: " + (err.code || err.message);
        // Still build with hardcoded fallback so at least the form is visible
        buildEditors(null);
      });

      saveBtn.addEventListener("click", function () {
        if (!isAdmin) return;
        var data = {};
        grid.querySelectorAll("textarea").forEach(function (ta) {
          var lines = ta.value.split("\n").map(function (l) { return l.trim(); }).filter(Boolean);
          data[ta.dataset.cat] = lines;
        });
        status.textContent = "Speichert…";
        window.fb.ref("workspace/defaults/sh").set(data).then(function () {
          status.textContent = "✓ gespeichert";
          window.appUI.toast("Standard-Liste gespeichert");
          setTimeout(function () { status.textContent = ""; }, 2000);
        }).catch(function (err) {
          status.textContent = "Fehler: " + (err.code || err.message);
        });
      });

      resetBtn.addEventListener("click", function () {
        if (!isAdmin) return;
        window.appUI.confirm({
          title: "Auf Original zurücksetzen?",
          description: "Die Workspace-Custom-Defaults für Shooting Check werden gelöscht. Bestehende Kunden behalten ihre Daten — neue Kunden starten wieder mit den eingebauten Defaults.",
          okLabel: "Zurücksetzen",
        }).then(function (ok) {
          if (!ok) return;
          window.fb.ref("workspace/defaults/sh").remove().then(function () {
            window.appUI.toast("Auf Original zurückgesetzt");
            buildEditors(null);
          }).catch(function (err) {
            status.textContent = "Fehler: " + (err.code || err.message);
          });
        });
      });
    }
    window.appUI.onAuth(initShDefaults);

    // ── CR (Creator Guide) defaults editor ─────────────────────────
    var CR_CATS = [
      { key: "outfit", label: "Outfit-Videos & Fitchecks" },
      { key: "speech", label: "Sprech-Content & WhatsApp-Funnel" },
      { key: "collab", label: "Creator-Collabs" },
      { key: "trends", label: "Trend- & Tanzvideos" },
      { key: "free",   label: "Free-Style" },
    ];
    var CR_HARDCODED = {
      outfit: [
        { text: "GRWM mit dem Piece", hook: "Hook: \"Heute zeig ich euch das Teil das ich seit 2 Wochen immer wieder anziehe…\"" },
        { text: "3 Outfits mit 1 Piece — ein Teil, drei Vibes", hook: "Hook: \"Ein Teil — drei komplett verschiedene Vibes. Ich mach's euch vor.\"" },
        { text: "Fitcheck Transition — Kamera runter, Outfit dran, Kamera hoch", hook: "Trending Format — einfach, schnell, effektiv" },
        { text: "\"Rate my Outfit\" — Community per Poll abstimmen lassen", hook: "Comments oder Story-Poll — maximales Engagement" },
        { text: "Streetstyle Cam — draußen laufen, Piece trägt sich selbst", hook: "Candid wirkt echter als Studio — einfach loslaufen, Kamera an" },
        { text: "Aesthetic Lookbook-Style — kein Gesicht nötig, nur das Piece", hook: "Für wer nicht reden will — Musik + Shots reicht komplett" },
      ],
      speech: [
        { text: "\"Ich bin in einer Community die ich euch zeigen muss\" — Story-Format", hook: "Persönlich, authentisch, direkt ansprechen — kein Sales-Talk" },
        { text: "\"Wir entscheiden den nächsten Drop — du auch?\" — direkter WhatsApp-CTA", hook: "Link in Bio, kurz und direkt, keine langen Erklärungen" },
        { text: "\"Ich hab mit abgestimmt — das ist der nächste Drop\" — Reaction Video", hook: "Echte Beteiligung zeigen, nicht nur werben" },
        { text: "Unboxing / Reveal des neuen Pieces — \"Das haben WIR mitentschieden…\"", hook: "Nicht \"ich hab bekommen\" — sondern \"WIR haben entschieden\"" },
      ],
      collab: [
        { text: "Duo-Fitcheck — zwei Creator, ein Piece, verschiedene Styles", hook: "Split-Screen oder harter Cut zwischen den zwei Looks" },
        { text: "\"Style Challenge\" — wer styled es besser? Community abstimmen lassen", hook: "Beide posten, beide verlinken — massives Engagement durch Voting" },
        { text: "Gemeinsamer GRWM / Content-Day zusammen drehen", hook: "Ein Tag, mehrere Videos, mehrere Accounts — alle profitieren" },
      ],
      trends: [
        { text: "Tanz-Trend im Outfit — einfach mitmachen, Piece sichtbar halten", hook: "Kein Kommentar nötig — Musik + Bewegung + Piece reicht" },
        { text: "Euphoria-Style Outfit Edit", hook: "Euphoria S3 läuft gerade — Cinematic Edit, Mood-Shots im Piece" },
        { text: "Coachella-Vibe Outfit", hook: "Hook: \"Coachella-Outfit aber make it Unsigned\" — Festival-Season läuft gerade" },
        { text: "Transition mit \"realization\" von Futureville oder Bruno Mars — I Just Might", hook: "Outfit-Reveal mit emotionalem Sound — starke Combo, gerade trending" },
      ],
      free: [
        { text: "Day-in-my-Life mit dem Piece — einfach mitfilmen", hook: "Kein Script, kein Plan — einfach filmen was passiert" },
        { text: "Persönliche Story — warum stehst du hinter der Brand?", hook: "Authentisch und ehrlich — das sind die Videos die viral gehen" },
        { text: "Spontane Outfit-Shots — kein Editing nötig, einfach abdrücken", hook: "Weniger ist mehr — raw content performt oft besser als polished" },
      ],
    };

    function initCrDefaults(me) {
      if (!window.fb || !me) return;
      var section = document.getElementById("defaultsSection");
      var wrap = document.getElementById("crDefaultsCats");
      var saveBtn = document.getElementById("crDefaultsSave");
      var resetBtn = document.getElementById("crDefaultsReset");
      var status = document.getElementById("crDefaultsStatus");
      if (!section || !wrap || !saveBtn || !resetBtn) return;

      var isAdmin = false;

      function makeRow(d) {
        var row = document.createElement("div");
        row.className = "cr-row flex items-center gap-2";
        row.innerHTML =
          '<input type="text" class="cr-text flex-1 text-[12px] border-[1.5px] border-line rounded-lg px-2 py-[6px] bg-white text-ink focus:border-brand outline-none" placeholder="Titel">' +
          '<input type="text" class="cr-hook flex-1 text-[11px] italic border-[1.5px] border-line rounded-lg px-2 py-[6px] bg-white text-ink-mute focus:border-brand outline-none" placeholder="Hook (optional)">' +
          '<button type="button" class="cr-del text-[14px] text-ink-mute hover:text-brand bg-transparent border-0 px-1 cursor-pointer" title="Löschen">×</button>';
        row.querySelector(".cr-text").value = (d && d.text) || "";
        row.querySelector(".cr-hook").value = (d && d.hook) || "";
        row.querySelector(".cr-del").addEventListener("click", function () {
          row.remove();
        });
        return row;
      }

      function buildEditors(values) {
        wrap.innerHTML = "";
        CR_CATS.forEach(function (c) {
          var box = document.createElement("div");
          box.className = "border-[0.5px] border-line rounded-[8px] px-3 py-2 bg-page";
          box.dataset.cat = c.key;
          box.innerHTML =
            '<div class="flex items-center justify-between mb-2">' +
            '<span class="text-[11px] font-bold text-ink">' + c.label + '</span>' +
            '<button type="button" class="cr-add text-[11px] text-brand hover:text-brand-dark bg-transparent border-0 cursor-pointer">+ hinzufügen</button>' +
            '</div>' +
            '<div class="cr-rows space-y-1"></div>';
          var rows = box.querySelector(".cr-rows");
          var items = (values && Array.isArray(values[c.key]))
            ? values[c.key]
            : (CR_HARDCODED[c.key] || []);
          items.forEach(function (d) { rows.appendChild(makeRow(d)); });
          box.querySelector(".cr-add").addEventListener("click", function () {
            rows.appendChild(makeRow({ text: "", hook: "" }));
            rows.lastChild.querySelector(".cr-text").focus();
          });
          wrap.appendChild(box);
        });
        wrap.querySelectorAll("input,button").forEach(function (el) {
          el.disabled = !isAdmin;
        });
        saveBtn.disabled = !isAdmin;
        resetBtn.disabled = !isAdmin;
      }

      window.fb.ref("admins/" + me.uid).on("value", function (s) {
        isAdmin = !!s.val();
        if (isAdmin) section.classList.remove("hidden");
        wrap.querySelectorAll("input,button").forEach(function (el) {
          el.disabled = !isAdmin;
        });
        saveBtn.disabled = !isAdmin;
        resetBtn.disabled = !isAdmin;
        if (!isAdmin) status.textContent = "nur lesen — du bist kein Admin";
      });

      window.fb.ref("workspace/defaults/cr").on("value", function (s) {
        var ae = document.activeElement;
        if (ae && ae.closest && ae.closest("#crDefaultsCats")) return;
        buildEditors(s.val());
      }, function (err) {
        status.textContent = "Lese-Fehler: " + (err.code || err.message);
        buildEditors(null);
      });

      saveBtn.addEventListener("click", function () {
        if (!isAdmin) return;
        var data = {};
        wrap.querySelectorAll("[data-cat]").forEach(function (box) {
          var cat = box.dataset.cat;
          var rows = box.querySelectorAll(".cr-row");
          var arr = [];
          rows.forEach(function (r) {
            var text = r.querySelector(".cr-text").value.trim();
            var hook = r.querySelector(".cr-hook").value.trim();
            if (text || hook) arr.push({ text: text, hook: hook });
          });
          data[cat] = arr;
        });
        status.textContent = "Speichert…";
        window.fb.ref("workspace/defaults/cr").set(data).then(function () {
          status.textContent = "✓ gespeichert";
          window.appUI.toast("Creator-Defaults gespeichert");
          setTimeout(function () { status.textContent = ""; }, 2000);
        }).catch(function (err) {
          status.textContent = "Fehler: " + (err.code || err.message);
        });
      });

      resetBtn.addEventListener("click", function () {
        if (!isAdmin) return;
        window.appUI.confirm({
          title: "Auf Original zurücksetzen?",
          description: "Die Workspace-Custom-Defaults für Creator Guide werden gelöscht. Bestehende Kunden behalten ihre Daten — neue Kunden starten wieder mit den eingebauten Defaults.",
          okLabel: "Zurücksetzen",
        }).then(function (ok) {
          if (!ok) return;
          window.fb.ref("workspace/defaults/cr").remove().then(function () {
            window.appUI.toast("Auf Original zurückgesetzt");
            buildEditors(null);
          }).catch(function (err) {
            status.textContent = "Fehler: " + (err.code || err.message);
          });
        });
      });
    }
    window.appUI.onAuth(initCrDefaults);
  })();
</script>
