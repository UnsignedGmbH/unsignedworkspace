---
import BaseLayout from "../layouts/BaseLayout.astro";
import PortalLiveBadge from "../components/PortalLiveBadge.astro";
import PortalFooter from "../components/PortalFooter.astro";
import BrandworkTimeline from "../components/BrandworkTimeline.astro";
---

<BaseLayout title="Kunden-Portal · Unsigned Workspace">
  <div
    class="min-h-screen flex flex-col bg-paper text-ink-warm relative overflow-x-hidden"
  >
    <!-- Slim header bar -->
    <header
      class="relative w-full bg-card border-b-[0.5px] border-line shrink-0"
    >
      <div
        class="relative px-4 md:px-6 lg:px-8 py-3 flex items-center gap-4 flex-wrap"
      >
        <img
          src="/brand/v-dark.png"
          alt="Unsigned"
          class="h-7 w-auto select-none pointer-events-none"
          loading="eager"
        />
        <span
          id="portalGreeting"
          class="text-[11px] font-bold tracking-[0.12em] uppercase text-ink-mute hidden sm:block"
          >Workspace</span
        >
        <div class="ml-auto" id="portalLiveSlot">
          <PortalLiveBadge />
        </div>
      </div>
    </header>

    <main
      class="flex-1 px-4 md:px-6 lg:px-8 py-5 fade-up"
      style="animation-delay:120ms"
    >
      <!-- Push-Permission Banner -->
      <div
        id="pushBanner"
        class="hidden mb-3 bg-brand-dim border-[0.5px] border-brand-border rounded-xl px-4 py-3 flex items-center gap-3 flex-wrap"
      >
        <span class="text-[18px] shrink-0" aria-hidden="true">🔔</span>
        <div class="flex-1 min-w-0">
          <div class="text-[12px] font-extrabold text-ink leading-tight" id="pushBannerTitle">Benachrichtigungen aktivieren?</div>
          <div class="text-[11px] text-ink-mute leading-snug" id="pushBannerSub">Bekomme Updates zur Produktion deiner Pieces direkt auf dein Gerät.</div>
        </div>
        <button
          type="button"
          id="pushBannerBtn"
          class="text-[11px] font-bold text-white bg-brand border-0 rounded-lg px-3 py-2 cursor-pointer shrink-0 hover:bg-[#a82929]"
        >Aktivieren</button>
        <button
          type="button"
          id="pushBannerDismiss"
          class="text-[11px] font-bold text-ink-mute bg-transparent border-0 cursor-pointer shrink-0"
          title="Banner verstecken">✕</button>
      </div>

      <!-- ═══════ TOOL OVERVIEW (Landing) ═══════ -->
      <div id="overviewView">
        <!-- HERO -->
        <section
          class="relative overflow-hidden rounded-2xl mb-5 md:mb-6 shadow-[0_10px_40px_rgba(0,0,0,0.08)]"
        >
          <div
            class="absolute inset-0 bg-[#0a0a0a] bg-no-repeat bg-cover bg-center"
            style="background-image: url('/brand/hintergrund.jpg');"
            aria-hidden="true"
          >
          </div>
          <div
            class="absolute inset-0 bg-gradient-to-br from-black/85 via-black/70 to-black/55"
            aria-hidden="true"
          >
          </div>
          <div class="relative px-5 md:px-8 py-6 md:py-8 text-white">
            <div class="flex items-start justify-between gap-4 flex-wrap">
              <div class="flex-1 min-w-0">
                <p
                  id="heroTimeGreet"
                  class="text-[11px] md:text-[12px] font-bold tracking-[0.18em] uppercase text-white/55"
                >
                  Willkommen
                </p>
                <h1
                  class="font-display italic font-extrabold text-[32px] md:text-[52px] leading-[0.95] tracking-[-0.01em] mt-1 mb-2"
                >
                  <span id="ovHelloName">…</span>
                </h1>
                <p
                  id="ovBrandSub"
                  class="text-[12px] md:text-[13px] text-white/65"
                >
                </p>
                <p
                  id="ovWelcomeText"
                  class="text-[13px] md:text-[14px] text-white/70 max-w-[520px] mt-3"
                >
                  Hier arbeiten wir gemeinsam an deiner Brand. Alles was du
                  eingibst, sieht dein Team bei Unsigned live.
                </p>
              </div>
              <img
                id="ovHeroLogo"
                src="/brand/wordmark-light.png"
                alt="Unsigned"
                class="hidden sm:block h-[52px] md:h-[78px] w-auto opacity-90 shrink-0 select-none pointer-events-none"
                loading="lazy"
              />
            </div>
          </div>
        </section>

        <BrandworkTimeline />

        <h2
          class="text-[10px] font-bold tracking-[0.12em] uppercase text-ink-mute mb-[10px] flex items-center gap-2"
        >
          <span class="w-1 h-3 bg-brand rounded-sm"></span>
          Tools
        </h2>
        <section
          id="ovGrid"
          class="grid grid-cols-2 sm:grid-cols-3 gap-2 md:gap-3"
        >
          <!-- gefüllt per JS -->
        </section>
      </div>

      <!-- ═══════ TOOL FULLSCREEN ═══════ -->
      <div id="toolView" class="hidden">
        <div class="flex items-center gap-3 mb-3 flex-wrap">
          <button
            type="button"
            id="toolBack"
            class="text-[11px] font-bold text-ink-soft bg-card border-[0.5px] border-line rounded-lg px-3 py-2 cursor-pointer hover:border-brand hover:text-brand"
            >← Übersicht</button
          >
          <span id="toolCrumb" class="text-[12px] font-bold text-ink">…</span>
        </div>
        <div
          class="bg-card border-[0.5px] border-line rounded-xl overflow-hidden h-[calc(100vh-220px)]"
        >
          <iframe
            id="portalFrame"
            src="about:blank"
            title="Tool"
            class="w-full h-full block border-0"></iframe>
        </div>
      </div>

      <div
        id="portalEmpty"
        class="hidden bg-card border-[0.5px] border-line rounded-2xl px-6 md:px-8 py-12 md:py-16 text-center max-w-[520px] mx-auto"
      >
        <div class="text-[48px] mb-4" aria-hidden="true">🔗</div>
        <h2 class="text-[20px] md:text-[22px] font-extrabold text-ink mb-2">
          Kein Portal-Link
        </h2>
        <p class="text-[13px] text-ink-soft leading-relaxed mb-1">
          Dieser Link ist unvollständig — der Raum-Code in der URL fehlt.
        </p>
        <p class="text-[12px] text-ink-mute leading-relaxed">
          Bitte öffne den Link, den du von Unsigned bekommen hast (E-Mail/WhatsApp), oder melde dich bei deinem Ansprechpartner.
        </p>
      </div>

      <div
        id="portalClosed"
        class="hidden bg-card border-[0.5px] border-line rounded-2xl px-6 md:px-8 py-12 md:py-16 text-center max-w-[520px] mx-auto"
      >
        <div class="text-[48px] mb-4">🔒</div>
        <h2 class="text-[20px] md:text-[22px] font-extrabold text-ink mb-2">
          Portal ist geschlossen
        </h2>
        <p class="text-[13px] text-ink-soft leading-relaxed">
          Dein Zugang zu diesem Workspace wurde beendet. Falls das ein
          Versehen ist, melde dich bitte direkt bei deinem Ansprechpartner
          bei Unsigned.
        </p>
      </div>
    </main>

    <PortalFooter />
  </div>

  <!-- ═══════ ONBOARDING DIALOG ═══════ -->
  <dialog
    id="onboardDlg"
    class="rounded-2xl border-[0.5px] border-line p-0 bg-card backdrop:bg-black/60 max-w-[440px] w-[90vw]"
  >
    <form id="onboardForm" class="p-6 space-y-4">
      <div>
        <h2 class="text-[18px] font-extrabold text-ink mb-1">Willkommen 👋</h2>
        <p class="text-[12px] text-ink-mute">
          Damit dein Team weiß wer gerade arbeitet — kurz dein Name und deine
          Brand.
        </p>
      </div>
      <label class="block">
        <span class="text-[10px] font-bold tracking-[0.12em] uppercase text-ink-mute">
          Dein Name
        </span>
        <input
          id="onbName"
          required
          maxlength="60"
          autocomplete="name"
          class="mt-1 block w-full text-[14px] font-semibold border-[1.5px] border-line rounded-lg px-[14px] py-[11px] outline-none text-ink bg-white focus:border-brand"
          placeholder="Lisa Müller"
        />
      </label>
      <label class="block">
        <span class="text-[10px] font-bold tracking-[0.12em] uppercase text-ink-mute">
          Deine Brand
        </span>
        <input
          id="onbBrand"
          required
          maxlength="60"
          class="mt-1 block w-full text-[14px] font-semibold border-[1.5px] border-line rounded-lg px-[14px] py-[11px] outline-none text-ink bg-white focus:border-brand"
          placeholder="z.B. Northern Studio"
        />
      </label>
      <button
        type="submit"
        class="w-full px-4 py-3 rounded-lg bg-brand text-white text-[13px] font-extrabold border-0 cursor-pointer hover:bg-brand-dark"
        >Loslegen →</button
      >
    </form>
  </dialog>
</BaseLayout>

<script is:inline>
  (function () {
    var room = new URLSearchParams(location.search).get("room");
    var liveSlot = document.getElementById("portalLiveSlot");
    var frame = document.getElementById("portalFrame");
    var emptyMsg = document.getElementById("portalEmpty");
    var greeting = document.getElementById("portalGreeting");
    var dlg = document.getElementById("onboardDlg");
    var form = document.getElementById("onboardForm");
    var nameInput = document.getElementById("onbName");
    var brandInput = document.getElementById("onbBrand");
    var STORAGE_KEY = "uw.portal.profile." + (room || "_");

    var TOOLS = [
      { id: "ai_guide", icon: "🤖", label: "Ai Guide",
        desc: "Moodboard, Prompts & Planung für dein Shooting" },
      { id: "bi", icon: "🪪", label: "Brand Identity",
        desc: "Logos, Farben, Typo & Vibe deiner Marke" },
      { id: "sh", icon: "📸", label: "Shooting",
        desc: "Checkliste · Moodboard · Archiv" },
      { id: "cr", icon: "📋", label: "Creator Guide",
        desc: "Briefing & Skripts für deine Inhalte" },
      { id: "design", icon: "🎨", label: "Design",
        desc: "Layouts & Visuals planen" },
      { id: "techpack", icon: "📐", label: "Techpack",
        desc: "Produktions-Specs pro Garment" },
      { id: "mk", icon: "📈", label: "Marketing Plan",
        desc: "Personal Brand · Ads · Email-Flows" },
      { id: "shop", icon: "🛒", label: "Shop",
        desc: "Shop-Optimierung & Drop-Planung" },
      { id: "content", icon: "🎬", label: "Content",
        desc: "Strategie · Hooks · Video-Ideen" },
      { id: "ads", icon: "📈", label: "Ads",
        desc: "Moodboard · 1:1 · 9:16" },
      { id: "social", icon: "💬", label: "Social Media",
        desc: "Profile · Highlights · Captions · WhatsApp" },
      { id: "production", icon: "🏭", label: "Produktion",
        desc: "Status & Stages deiner Pieces" },
      { id: "calculator", icon: "💰", label: "Kalkulator",
        desc: "VK-Preis pro Piece kalkulieren" },
    ];

    if (!room) {
      document.getElementById("overviewView").style.display = "none";
      document.getElementById("toolView").classList.add("hidden");
      emptyMsg.classList.remove("hidden");
      return;
    }

    var roomEl = liveSlot.querySelector("[data-room]");
    if (roomEl) roomEl.textContent = room;

    // PWA-Helper: Raum-Code im Browser merken, damit Kunden bei Home-Screen-
    // Tap (Manifest-Start = "/") automatisch zurueck zu ihrem Portal kommen.
    // index.astro liest diesen Wert wenn keine Owner-Auth vorliegt.
    try { localStorage.setItem("uw.last_portal_room", room); } catch (e) {}

    var profile = null;
    var currentTool = null;
    var heartbeat = null;
    var pingFn = function () {};
    var TOOL_PROGRESS = {}; // tool-id → pct (0-100)
    function _clamp(n){ n = parseInt(n, 10) || 0; return Math.max(0, Math.min(100, n)); }

    function showClosed() {
      document.getElementById("overviewView").style.display = "none";
      document.getElementById("toolView").classList.add("hidden");
      emptyMsg.classList.add("hidden");
      document.getElementById("portalClosed").classList.remove("hidden");
      if (liveSlot) liveSlot.style.display = "none";
    }

    // Check if room was closed (customer deleted) BEFORE doing anything else.
    function checkClosedThen(cb) {
      window.fb.ref("rooms/" + room + "/_closed").once("value")
        .then(function (s) {
          if (s.exists()) { showClosed(); return; }
          cb();
        })
        .catch(function () { cb(); }); // fail-open, proceed if check fails
    }

    // ── Anonymous Auth ─────────────────────────────────────
    function bootAuth() {
      var auth = window.firebase.auth();
      auth.setPersistence(window.firebase.auth.Auth.Persistence.LOCAL)
        .catch(function () {});
      auth.onAuthStateChanged(function (u) {
        if (u) { afterAuth(u); return; }
        auth.signInAnonymously().catch(function (e) {
          console.error("[portal] anon sign-in failed:", e);
          window.toast(
            "Anmeldung fehlgeschlagen — bitte Seite neu laden. (" +
              (e.code || e.message) + ")",
            "error",
            { ttl: 0 }
          );
        });
      });
    }

    function afterAuth(user) {
      try {
        var raw = localStorage.getItem(STORAGE_KEY);
        if (raw) profile = JSON.parse(raw);
      } catch (e) {}
      if (profile && profile.name && profile.brand) {
        startPortal(user);
        return;
      }
      // Cross-device recognition: another device on this room may already have
      // completed onboarding. Adopt the newest existing profile instead of
      // re-prompting.
      window.fb.ref("rooms/" + room + "/clientProfile").once("value")
        .then(function (s) {
          var v = s.val() || {};
          var keys = Object.keys(v);
          if (!keys.length) { showOnboard(user); return; }
          var newest = null;
          keys.forEach(function (k) {
            var p = v[k] || {};
            if (p.name && p.brand &&
                (!newest || (p.joinedAt || 0) > (newest.joinedAt || 0))) {
              newest = p;
            }
          });
          if (!newest) { showOnboard(user); return; }
          profile = {
            uid: user.uid,
            name: newest.name,
            brand: newest.brand,
            joinedAt: Date.now(),
          };
          try { localStorage.setItem(STORAGE_KEY, JSON.stringify(profile)); } catch (e2) {}
          window.fb
            .ref("rooms/" + room + "/clientProfile/" + user.uid)
            .set({ name: newest.name, brand: newest.brand, joinedAt: window.fb.ts() })
            .catch(function (err) {
              console.error("[portal] clientProfile mirror failed:", err);
            });
          startPortal(user);
        })
        .catch(function () { showOnboard(user); }); // fail-open
    }

    function showOnboard(user) {
      try { dlg.showModal(); } catch (e) {}
      setTimeout(function () { nameInput.focus(); }, 30);
      form.addEventListener("submit", function (e) {
        e.preventDefault();
        var n = nameInput.value.trim();
        var b = brandInput.value.trim();
        if (!n || !b) return;
        profile = { uid: user.uid, name: n, brand: b, joinedAt: Date.now() };
        try { localStorage.setItem(STORAGE_KEY, JSON.stringify(profile)); } catch (e2) {}
        window.fb
          .ref("rooms/" + room + "/clientProfile/" + user.uid)
          .set({ name: n, brand: b, joinedAt: window.fb.ts() })
          .catch(function (err) {
            console.error("[portal] clientProfile write failed:", err);
          });
        try { dlg.close(); } catch (e3) {}
        startPortal(user);
      });
    }

    // ── Portal start: Greeting + Grid ──────────────────────
    function startPortal(user) {
      if (greeting) greeting.textContent = profile.name + " · " + profile.brand;
      document.getElementById("ovHelloName").textContent = profile.name;
      var brandSub = document.getElementById("ovBrandSub");
      if (brandSub) brandSub.textContent = profile.brand;
      var timeGreet = document.getElementById("heroTimeGreet");
      if (timeGreet) {
        var h = new Date().getHours();
        var g = "Willkommen";
        if (h < 5) g = "Gute Nacht";
        else if (h < 11) g = "Guten Morgen";
        else if (h < 17) g = "Guten Tag";
        else if (h < 22) g = "Guten Abend";
        timeGreet.textContent = g;
      }

      pingFn = function (tool) {
        window.fb
          .ref("rooms/" + room + "/clientActivity")
          .set({
            tool: tool || "_idle",
            ts: window.fb.ts(),
            uid: user.uid,
            name: profile.name,
            brand: profile.brand,
          })
          .catch(function () {});
      };

      renderGrid();
      attachToolProgress();
      pingFn(null); // beigetreten, aber noch in Übersicht

      heartbeat = setInterval(function () {
        if (document.visibilityState === "visible") pingFn(currentTool);
      }, 60000);
      document.addEventListener("visibilitychange", function () {
        if (document.visibilityState === "visible") pingFn(currentTool);
      });
      window.addEventListener("beforeunload", function () {
        clearInterval(heartbeat);
      });
    }

    // Techpack hat kein einzelner %-Wert (mehrere Packs pro Customer) — eigene Card.
    function _tpPortalCard(t) {
      var parts = [];
      parts.push('<button type="button" data-tool="' + t.id + '"');
      parts.push(' class="tool-card group bg-card border-[0.5px] border-line rounded-xl p-3 md:p-[14px] flex flex-col gap-2 hover:border-brand-border hover:bg-brand-dim hover:shadow-[0_4px_16px_rgba(193,48,48,0.08)] transition-all text-left cursor-pointer min-w-0">');
      parts.push('<div class="flex items-start gap-3 min-w-0">');
      parts.push('<span class="w-9 h-9 md:w-10 md:h-10 rounded-lg bg-brand-dim flex items-center justify-center text-[18px] md:text-[20px] shrink-0 group-hover:bg-brand group-hover:text-white transition-colors">' + t.icon + '</span>');
      parts.push('<div class="flex-1 min-w-0">');
      parts.push('<div class="text-[12px] md:text-[13px] font-extrabold text-ink truncate">' + t.label + '</div>');
      parts.push('<div class="text-[10px] md:text-[11px] text-ink-mute mt-[1px] truncate">' + t.desc + '</div>');
      parts.push('</div></div>');
      parts.push('<div class="text-[10px] text-ink-soft mt-1">&rarr; Pro Garment ein Techpack</div>');
      parts.push('</button>');
      return parts.join("");
    }

    function _calcPortalCard(t) {
      var parts = [];
      parts.push('<button type="button" data-tool="' + t.id + '"');
      parts.push(' class="tool-card group bg-card border-[0.5px] border-line rounded-xl p-3 md:p-[14px] flex flex-col gap-2 hover:border-brand-border hover:bg-brand-dim hover:shadow-[0_4px_16px_rgba(193,48,48,0.08)] transition-all text-left cursor-pointer min-w-0">');
      parts.push('<div class="flex items-start gap-3 min-w-0">');
      parts.push('<span class="w-9 h-9 md:w-10 md:h-10 rounded-lg bg-brand-dim flex items-center justify-center text-[18px] md:text-[20px] shrink-0 group-hover:bg-brand group-hover:text-white transition-colors">' + t.icon + '</span>');
      parts.push('<div class="flex-1 min-w-0">');
      parts.push('<div class="text-[12px] md:text-[13px] font-extrabold text-ink truncate">' + t.label + '</div>');
      parts.push('<div class="text-[10px] md:text-[11px] text-ink-mute mt-[1px] truncate">' + t.desc + '</div>');
      parts.push('</div></div>');
      parts.push('<div class="text-[10px] text-ink-soft mt-1">&rarr; Multi-Tab pro Piece</div>');
      parts.push('</button>');
      return parts.join("");
    }

    function renderGrid() {
      var grid = document.getElementById("ovGrid");
      grid.innerHTML = TOOLS.map(function (t) {
        if (t.id === "techpack") return _tpPortalCard(t);
        if (t.id === "calculator") return _calcPortalCard(t);
        var pct = TOOL_PROGRESS[t.id] || 0;
        return (
          '<button type="button" data-tool="' + t.id + '"' +
          ' class="tool-card group bg-card border-[0.5px] border-line rounded-xl p-3 md:p-[14px] flex flex-col gap-2 hover:border-brand-border hover:bg-brand-dim hover:shadow-[0_4px_16px_rgba(193,48,48,0.08)] transition-all text-left cursor-pointer min-w-0">' +
          '<div class="flex items-start gap-3 min-w-0">' +
          '<span class="w-9 h-9 md:w-10 md:h-10 rounded-lg bg-brand-dim flex items-center justify-center text-[18px] md:text-[20px] shrink-0 group-hover:bg-brand group-hover:text-white transition-colors">' +
          t.icon + '</span>' +
          '<div class="flex-1 min-w-0">' +
          '<div class="flex items-center gap-2 min-w-0">' +
          '<div class="text-[12px] md:text-[13px] font-extrabold text-ink truncate flex-1 min-w-0">' + t.label + '</div>' +
          '<span class="text-[10px] font-bold text-ink-soft shrink-0">' + pct + '%</span>' +
          '</div>' +
          '<div class="text-[10px] md:text-[11px] text-ink-mute mt-[1px] truncate">' + t.desc + '</div>' +
          '</div>' +
          '</div>' +
          '<div class="h-[3px] bg-[#eee] rounded-sm overflow-hidden mt-1"><div class="h-full bg-brand rounded-sm transition-all" style="width:' + pct + '%"></div></div>' +
          '</button>'
        );
      }).join("");
      grid.querySelectorAll(".tool-card").forEach(function (b) {
        b.addEventListener("click", function () { openTool(b.dataset.tool); });
      });
      if (window.BWTimeline) {
        window.BWTimeline.render(function (toolKey) {
          return TOOL_PROGRESS[toolKey] || 0;
        }, function (toolKey) {
          openTool(toolKey);
        }, function (toolKey) {
          if (toolKey !== "production") return null;
          return buildProductionStatusPortal();
        });
      }
    }

    var _portalProdCards = null, _portalProdColumns = null;
    function buildProductionStatusPortal() {
      if (!_portalProdCards || !_portalProdColumns) return { label: "—", sub: "Produktion · Sampling · Bulk" };
      var pieceIds = Object.keys(_portalProdCards).filter(function (k) { return !_portalProdCards[k].archived; });
      if (pieceIds.length === 0) {
        return { label: "0 Pieces", sub: "Noch nichts in Produktion" };
      }
      var label = pieceIds.length + " " + (pieceIds.length === 1 ? "Piece" : "Pieces");
      var sorted = pieceIds.sort(function (a, b) { return (_portalProdCards[a].createdAt || 0) - (_portalProdCards[b].createdAt || 0); });
      var parts = sorted.slice(0, 2).map(function (pid) {
        var card = _portalProdCards[pid];
        var colLabel = (_portalProdColumns[card.columnId] && _portalProdColumns[card.columnId].label) || "?";
        return (card.name || "Piece") + " → " + colLabel;
      });
      if (sorted.length > 2) parts.push("… +" + (sorted.length - 2));
      return { label: label, sub: parts.join(" · "), includeInAvg: false };
    }

    // Subscribe to per-tool progress and re-render the grid whenever any tool's pct changes.
    function attachToolProgress() {
      function setPct(toolId, pct){
        var p = _clamp(pct);
        if (TOOL_PROGRESS[toolId] === p) return;
        TOOL_PROGRESS[toolId] = p;
        // Re-render only if overview is currently visible
        if (!document.getElementById("overviewView").classList.contains("hidden")) renderGrid();
      }
      // Tools that already write a *_pct field directly
      window.fb.ref("rooms/" + room + "/sh_pct").on("value", function(s){ setPct("sh", s.val()); });
      window.fb.ref("rooms/" + room + "/cr_pct").on("value", function(s){ setPct("cr", s.val()); });
      window.fb.ref("rooms/" + room + "/mk_pct").on("value", function(s){ setPct("mk", s.val()); });
      window.fb.ref("rooms/" + room + "/ag_pct").on("value", function(s){ setPct("ai_guide", s.val()); });
      window.fb.ref("rooms/" + room + "/shop_pct").on("value", function(s){ setPct("shop", s.val()); });
      window.fb.ref("rooms/" + room + "/social_pct").on("value", function(s){ setPct("social", s.val()); });
      window.fb.ref("rooms/" + room + "/content_pct").on("value", function(s){ setPct("content", s.val()); });
      // Production: cards + columns für Status-Text-Mode in Roadmap
      window.fb.ref("rooms/" + room + "/production/cards").on("value", function(s){
        _portalProdCards = s.val() || {};
        if (typeof renderGrid === "function") renderGrid();
      });
      window.fb.ref("rooms/" + room + "/production/columns").on("value", function(s){
        _portalProdColumns = s.val() || {};
        if (typeof renderGrid === "function") renderGrid();
      });
      // BI: derive from rooms/<room>/data/fields (count fields with text or images)
      window.fb.ref("rooms/" + room + "/data/fields").on("value", function(s){
        var v = s.val() || {};
        var keys = Object.keys(v);
        if (!keys.length) { setPct("bi", 0); return; }
        var filled = 0;
        keys.forEach(function(k){
          var f = v[k] || {};
          var hasText = (f.text || "").trim().length > 0;
          var hasImg = Array.isArray(f.images) && f.images.length > 0;
          if (hasText || hasImg) filled++;
        });
        setPct("bi", Math.round((filled / keys.length) * 100));
      });
      // Design: derive from rooms/<room>/design (count of items, capped at 5%/item)
      window.fb.ref("rooms/" + room + "/design").on("value", function(s){
        var v = s.val() || {};
        var n = 0;
        Object.keys(v).forEach(function(k){
          var node = v[k];
          if (node && typeof node === "object") n += Object.keys(node).length;
        });
        setPct("design", Math.min(100, n * 5));
      });
    }

    function openTool(toolId, extraParams) {
      var t = TOOLS.find(function (x) { return x.id === toolId; });
      if (!t) return;
      currentTool = toolId;
      document.getElementById("overviewView").classList.add("hidden");
      document.getElementById("toolView").classList.remove("hidden");
      document.getElementById("toolCrumb").textContent = t.icon + " " + t.label;
      var url = "/tools/" + toolId + ".html?room=" + encodeURIComponent(room) + "&owner=1&role=customer";
      if (extraParams && typeof extraParams === 'object') {
        Object.keys(extraParams).forEach(function (k) {
          if (extraParams[k] != null) url += '&' + k + '=' + encodeURIComponent(extraParams[k]);
        });
      }
      frame.src = url;
      pingFn(toolId);
    }

    // Cross-iframe Tool-Switch via postMessage (z.B. von Production → Techpack)
    window.addEventListener('message', function (e) {
      if (typeof e.origin === 'string' && e.origin !== window.location.origin) return;
      var d = e.data || {};
      if (d.type === 'openTool' && d.tool) {
        var extras = {};
        if (d.packId) extras.openPack = d.packId;
        openTool(d.tool, extras);
      }
    });

    function backToOverview() {
      currentTool = null;
      document.getElementById("toolView").classList.add("hidden");
      document.getElementById("overviewView").classList.remove("hidden");
      frame.src = "about:blank";
      pingFn(null);
      // Wichtig: Grid neu rendern. Listener haben TOOL_PROGRESS waehrend der
      // Customer im Tool war aktualisiert (renderGrid wird dort skipped weil
      // overview hidden ist). Ohne diesen Aufruf zeigt das Dashboard nach
      // Rueckkehr aus einem Tool die alten %-Werte bis zum naechsten Refresh.
      renderGrid();
    }
    document.getElementById("toolBack").addEventListener("click", backToOverview);

    function waitForFb(cb) {
      if (window.fb && window.firebase) cb();
      else setTimeout(function () { waitForFb(cb); }, 50);
    }
    waitForFb(function () { checkClosedThen(bootAuth); });

    // Workspace-Brand applied to portal — name in tagline, custom welcome text, logo swap
    function applyBrand() {
      if (!window.fb) return setTimeout(applyBrand, 100);
      window.fb.ref("workspace/brand").on("value", function (s) {
        var b = s.val() || {};
        var brandName = (b.name && b.name.trim()) || "Unsigned";
        var welcome = b.welcome && b.welcome.trim();
        var logo = b.logo && typeof b.logo === "string" ? b.logo : "";
        var welcomeEl = document.getElementById("ovWelcomeText");
        if (welcomeEl) {
          welcomeEl.textContent = welcome ||
            ("Hier arbeiten wir gemeinsam an deiner Brand. Alles was du eingibst, sieht dein Team bei " + brandName + " live.");
        }
        var logoEl = document.getElementById("ovHeroLogo");
        if (logoEl) logoEl.src = logo || "/brand/wordmark-light.png";
      });
    }
    applyBrand();

    // Live-react to closure: if owner deletes during a session, lock immediately.
    function watchClosed() {
      if (!window.fb) return setTimeout(watchClosed, 200);
      window.fb.ref("rooms/" + room + "/_closed").on("value", function (s) {
        if (s.exists()) {
          if (heartbeat) clearInterval(heartbeat);
          showClosed();
        }
      });
    }
    watchClosed();
  })();
</script>

<!-- Push-Notification Setup (Customer-Portal) -->
<script src="/push-client.js" defer></script>
<script is:inline>
(function () {
  var banner = document.getElementById('pushBanner');
  var btn = document.getElementById('pushBannerBtn');
  var dismiss = document.getElementById('pushBannerDismiss');
  var titleEl = document.getElementById('pushBannerTitle');
  var subEl = document.getElementById('pushBannerSub');
  if (!banner || !btn) return;

  var DISMISS_KEY = 'unsigned_push_dismissed_until';

  function dismissedRecently() {
    try {
      var until = parseInt(localStorage.getItem(DISMISS_KEY) || '0', 10);
      return until > Date.now();
    } catch (e) { return false; }
  }

  function setDismissed(days) {
    try {
      localStorage.setItem(DISMISS_KEY, String(Date.now() + days * 86400000));
    } catch (e) {}
  }

  function getRoom() {
    var p = new URLSearchParams(location.search);
    return p.get('room') || (window.PORTAL_ROOM || null);
  }

  function update() {
    if (!window.UWPush) { setTimeout(update, 200); return; }
    if (!UWPush.isSupported()) { banner.classList.add('hidden'); return; }
    var st = UWPush.permState();
    var room = getRoom();
    if (!room) { banner.classList.add('hidden'); return; }

    if (st === 'granted') {
      banner.classList.add('hidden');
      UWPush.refresh(room).catch(function () {});
    } else if (st === 'denied') {
      banner.classList.remove('hidden');
      titleEl.textContent = 'Benachrichtigungen sind blockiert';
      subEl.textContent = 'Erlaube sie in den Browser-Einstellungen (Safari → Einstellungen → Websites → Mitteilungen).';
      btn.style.display = 'none';
    } else {
      // 'default' — noch nicht gefragt
      if (dismissedRecently()) { banner.classList.add('hidden'); return; }
      banner.classList.remove('hidden');
      // iOS-PWA-Hinweis falls Safari (nicht im Homescreen-Mode)
      var ua = navigator.userAgent || '';
      var iOSnotStandalone = (/iPhone|iPad/.test(ua)) && !UWPush.isIOSStandalone();
      if (iOSnotStandalone) {
        titleEl.textContent = 'Für Push-Benachrichtigungen: App zum Home-Bildschirm';
        subEl.textContent = 'Safari-Teilen-Button → "Zum Home-Bildschirm". Dann diese App vom Homescreen öffnen und nochmal hier klicken.';
        btn.textContent = 'OK, verstanden';
        btn.onclick = function () { setDismissed(2); banner.classList.add('hidden'); };
      } else {
        titleEl.textContent = 'Benachrichtigungen aktivieren?';
        subEl.textContent = 'Bekomme Updates zur Produktion deiner Pieces direkt auf dein Gerät.';
        btn.textContent = 'Aktivieren';
        btn.onclick = function () {
          btn.disabled = true;
          btn.textContent = 'Aktiviere …';
          UWPush.subscribe(room).then(function () {
            banner.classList.add('hidden');
          }).catch(function (e) {
            btn.disabled = false;
            btn.textContent = 'Aktivieren';
            subEl.textContent = (e && e.message) || 'Konnte nicht aktiviert werden.';
          });
        };
      }
    }
  }

  dismiss.onclick = function () { setDismissed(7); banner.classList.add('hidden'); };
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', update);
  } else {
    update();
  }
})();
</script>
