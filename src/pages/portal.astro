---
import BaseLayout from "../layouts/BaseLayout.astro";
import PortalLiveBadge from "../components/PortalLiveBadge.astro";
import PortalFooter from "../components/PortalFooter.astro";
---

<BaseLayout title="Kunden-Portal · Unsigned Workspace">
  <div
    class="min-h-screen flex flex-col bg-paper text-ink-warm grain-overlay relative overflow-x-hidden"
  >
    <header
      class="relative w-full bg-brand text-white fade-up shrink-0"
      style="animation-delay:60ms"
    >
      <div
        aria-hidden="true"
        class="absolute inset-y-0 right-[-80px] w-[260px] rotate-12 bg-brand-dark opacity-25 pointer-events-none"
      >
      </div>
      <div
        class="relative px-6 lg:px-12 py-5 flex items-center gap-6 flex-wrap"
      >
        <div class="flex items-baseline gap-3">
          <span
            class="font-display italic font-extrabold text-[28px] leading-none tracking-[-0.01em]"
            >Unsigned</span
          >
          <span
            class="brand-script text-[18px] text-white/90 leading-none"
            style="color:#fff"
            >Workspace</span
          >
        </div>
        <span class="hidden md:block ml-2 h-6 w-px bg-white/30"></span>
        <span
          id="portalGreeting"
          class="hidden md:block font-sans uppercase tracking-[0.22em] text-[10px] text-white/70"
          >Brand Identity &amp; Tools</span
        >
        <div class="ml-auto" id="portalLiveSlot">
          <PortalLiveBadge />
        </div>
      </div>
    </header>

    <main
      class="flex-1 px-6 lg:px-12 py-5 fade-up"
      style="animation-delay:200ms"
    >
      <div class="flex gap-2 mb-3 flex-wrap" id="portalTabs">
        <button
          type="button"
          data-tool="ai_guide"
          class="ptab px-4 py-2 rounded-full text-[12px] font-bold cursor-pointer border-0 bg-brand text-white"
          >🤖 Ai Guide</button
        >
        <button
          type="button"
          data-tool="bi"
          class="ptab px-4 py-2 rounded-full text-[12px] font-bold cursor-pointer border-[0.5px] bg-card text-ink-mute border-line"
          >🪪 Brand Identity</button
        >
        <button
          type="button"
          data-tool="sh"
          class="ptab px-4 py-2 rounded-full text-[12px] font-bold cursor-pointer border-[0.5px] bg-card text-ink-mute border-line"
          >📸 Shooting</button
        >
        <button
          type="button"
          data-tool="cr"
          class="ptab px-4 py-2 rounded-full text-[12px] font-bold cursor-pointer border-[0.5px] bg-card text-ink-mute border-line"
          >📋 Creator Guide</button
        >
        <button
          type="button"
          data-tool="design"
          class="ptab px-4 py-2 rounded-full text-[12px] font-bold cursor-pointer border-[0.5px] bg-card text-ink-mute border-line"
          >🎨 Design</button
        >
      </div>

      <div
        class="bg-card border-[0.5px] border-line rounded-xl overflow-hidden h-[calc(100vh-220px)]"
      >
        <iframe
          id="portalFrame"
          src="about:blank"
          title="Tool"
          class="w-full h-full block border-0"></iframe>
      </div>

      <p
        id="portalEmpty"
        class="hidden text-center text-[13px] text-ink-soft py-12"
      >
        Kein Raum-Code in der URL. Bitte den Link von Unsigned öffnen.
      </p>
    </main>

    <PortalFooter />
  </div>

  <!-- ════════ ONBOARDING DIALOG ════════ -->
  <dialog
    id="onboardDlg"
    class="rounded-2xl border-[0.5px] border-line p-0 bg-card backdrop:bg-black/60 max-w-[440px] w-[90vw]"
  >
    <form id="onboardForm" class="p-6 space-y-4">
      <div>
        <h2 class="text-[18px] font-extrabold text-ink mb-1">Willkommen 👋</h2>
        <p class="text-[12px] text-ink-mute">
          Damit dein Team weiß wer gerade arbeitet — kurz dein Name und deine
          Brand.
        </p>
      </div>
      <label class="block">
        <span class="text-[10px] font-bold tracking-[0.12em] uppercase text-ink-mute">
          Dein Name
        </span>
        <input
          id="onbName"
          required
          maxlength="60"
          autocomplete="name"
          class="mt-1 block w-full text-[14px] font-semibold border-[1.5px] border-line rounded-lg px-[14px] py-[11px] outline-none text-ink bg-white focus:border-brand"
          placeholder="Lisa Müller"
        />
      </label>
      <label class="block">
        <span class="text-[10px] font-bold tracking-[0.12em] uppercase text-ink-mute">
          Deine Brand
        </span>
        <input
          id="onbBrand"
          required
          maxlength="60"
          class="mt-1 block w-full text-[14px] font-semibold border-[1.5px] border-line rounded-lg px-[14px] py-[11px] outline-none text-ink bg-white focus:border-brand"
          placeholder="z.B. Northern Studio"
        />
      </label>
      <button
        type="submit"
        class="w-full px-4 py-3 rounded-lg bg-brand text-white text-[13px] font-extrabold border-0 cursor-pointer hover:bg-brand-dark"
        >Loslegen →</button
      >
    </form>
  </dialog>
</BaseLayout>

<script is:inline>
  (function () {
    var room = new URLSearchParams(location.search).get("room");
    var liveSlot = document.getElementById("portalLiveSlot");
    var frame = document.getElementById("portalFrame");
    var tabsContainer = document.getElementById("portalTabs");
    var tabs = tabsContainer.querySelectorAll(".ptab");
    var emptyMsg = document.getElementById("portalEmpty");
    var greeting = document.getElementById("portalGreeting");
    var dlg = document.getElementById("onboardDlg");
    var form = document.getElementById("onboardForm");
    var nameInput = document.getElementById("onbName");
    var brandInput = document.getElementById("onbBrand");
    var STORAGE_KEY = "uw.portal.profile." + (room || "_");

    if (!room) {
      frame.style.display = "none";
      tabsContainer.style.display = "none";
      emptyMsg.classList.remove("hidden");
      return;
    }

    var roomEl = liveSlot.querySelector("[data-room]");
    if (roomEl) roomEl.textContent = room;

    var profile = null;
    var currentTool = "ai_guide";
    var heartbeat = null;

    // ── Anonymous Auth + Profile bootstrap ─────────────────
    function bootAuth() {
      var auth = window.firebase.auth();
      auth.setPersistence(window.firebase.auth.Auth.Persistence.LOCAL)
        .catch(function () {});
      auth.onAuthStateChanged(function (u) {
        if (u) {
          afterAuth(u);
          return;
        }
        auth.signInAnonymously().catch(function (e) {
          console.error("[portal] anon sign-in failed:", e);
          alert(
            "Anmeldung fehlgeschlagen — bitte Seite neu laden. (" +
              (e.code || e.message) +
              ")"
          );
        });
      });
    }

    function afterAuth(user) {
      // Lokal gemerktes Profil sofort übernehmen
      try {
        var raw = localStorage.getItem(STORAGE_KEY);
        if (raw) profile = JSON.parse(raw);
      } catch (e) {}

      if (profile && profile.name && profile.brand) {
        startPortal(user);
      } else {
        showOnboard(user);
      }
    }

    // ── Onboarding ─────────────────────────────────────────
    function showOnboard(user) {
      try { dlg.showModal(); } catch (e) {}
      setTimeout(function () { nameInput.focus(); }, 30);
      form.addEventListener("submit", function (e) {
        e.preventDefault();
        var n = nameInput.value.trim();
        var b = brandInput.value.trim();
        if (!n || !b) return;
        profile = {
          uid: user.uid,
          name: n,
          brand: b,
          joinedAt: Date.now(),
        };
        try { localStorage.setItem(STORAGE_KEY, JSON.stringify(profile)); } catch (e) {}
        // In RTDB schreiben — eine Schreibung pro Kunde
        window.fb
          .ref("rooms/" + room + "/clientProfile/" + user.uid)
          .set({
            name: n,
            brand: b,
            joinedAt: window.fb.ts(),
          })
          .catch(function (err) {
            console.error("[portal] clientProfile write failed:", err);
          });
        try { dlg.close(); } catch (e2) {}
        startPortal(user);
      });
    }

    // ── Tool starten + Heartbeat ───────────────────────────
    function startPortal(user) {
      if (greeting) greeting.textContent =
        profile.name + " · " + profile.brand;

      function ping(tool) {
        window.fb
          .ref("rooms/" + room + "/clientActivity")
          .set({
            tool: tool,
            ts: window.fb.ts(),
            uid: user.uid,
            name: profile.name,
            brand: profile.brand,
          })
          .catch(function () {});
      }

      function setTool(tool) {
        var btn = tabsContainer.querySelector('[data-tool="' + tool + '"]');
        if (!btn) return;
        currentTool = tool;
        tabs.forEach(function (b) {
          var on = b === btn;
          b.classList.toggle("bg-brand", on);
          b.classList.toggle("text-white", on);
          b.classList.toggle("border-0", on);
          b.classList.toggle("bg-card", !on);
          b.classList.toggle("text-ink-mute", !on);
          b.classList.toggle("border-[0.5px]", !on);
          b.classList.toggle("border-line", !on);
        });
        frame.src =
          "/tools/" + tool + ".html?room=" + encodeURIComponent(room) + "&owner=1";
        ping(tool);
      }
      tabs.forEach(function (b) {
        b.addEventListener("click", function () { setTool(b.dataset.tool); });
      });

      heartbeat = setInterval(function () {
        if (document.visibilityState === "visible") ping(currentTool);
      }, 60000);
      document.addEventListener("visibilitychange", function () {
        if (document.visibilityState === "visible") ping(currentTool);
      });
      window.addEventListener("beforeunload", function () {
        clearInterval(heartbeat);
      });

      setTool(currentTool);
    }

    // Auf Firebase warten (BaseLayout init), dann starten
    function waitForFb(cb) {
      if (window.fb && window.firebase) cb();
      else setTimeout(function () { waitForFb(cb); }, 50);
    }
    waitForFb(bootAuth);
  })();
</script>
