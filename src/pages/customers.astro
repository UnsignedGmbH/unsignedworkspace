---
import AppLayout from "../layouts/AppLayout.astro";

const filters = [
  { id: "all", label: "Alle" },
  { id: "mine", label: "Meine" },
  { id: "active", label: "Aktiv" },
  { id: "archived", label: "Archiviert" },
];
---

<AppLayout title="Kunden" active="customers">
  <!-- Such-Leiste: filtert die Liste live, persistiert in URL (?q=) -->
  <div class="relative mb-3">
    <span
      class="absolute left-3 top-1/2 -translate-y-1/2 text-ink-mute text-[14px] pointer-events-none"
      aria-hidden="true">🔍</span>
    <input
      id="searchInput"
      type="search"
      placeholder="Kunde suchen — Name oder Raum-Code…"
      class="block w-full text-[13px] font-semibold border-[1.5px] border-line rounded-lg pl-10 pr-10 py-[10px] outline-none text-ink bg-white focus:border-brand"
      autocomplete="off"
      spellcheck="false"
    />
    <button
      type="button"
      id="searchClear"
      class="hidden absolute right-2 top-1/2 -translate-y-1/2 w-7 h-7 flex items-center justify-center text-ink-mute hover:text-ink bg-transparent border-0 rounded-md cursor-pointer text-[16px]"
      title="Suche löschen (Esc)"
      aria-label="Suche löschen">✕</button>
  </div>
  <div class="flex gap-[6px] mb-[14px] flex-wrap items-center" id="filterBar">
    {
      filters.map((f, i) => (
        <button
          type="button"
          data-filter={f.id}
          class:list={[
            "filter-pill px-[14px] py-[5px] rounded-full border-[0.5px] text-[11px] font-bold cursor-pointer",
            i === 0
              ? "bg-brand border-brand text-white"
              : "border-line text-ink-mute bg-transparent",
          ]}
        >
          {f.label}
        </button>
      ))
    }

    <button
      id="exportBtn"
      type="button"
      class="ml-auto px-[14px] py-[5px] rounded-full bg-card border-[0.5px] border-line text-[11px] font-bold cursor-pointer hover:border-brand hover:text-brand text-ink-soft"
      title="Alle Kunden + Räume als JSON-Backup herunterladen"
      >⬇ Backup-Export</button
    >
    <button
      id="newCustomerBtn"
      type="button"
      class="px-[14px] py-[5px] rounded-full bg-brand text-white text-[11px] font-bold cursor-pointer hover:bg-brand-dark"
      >➕ Neuer Kunde</button
    >
  </div>

  <div id="loadingMsg" class="py-10">
    <div class="flex flex-col items-center justify-center gap-3">
      <span class="w-7 h-7 rounded-full border-[3px] border-line border-t-brand animate-spin" aria-hidden="true"></span>
      <span class="text-[12px] text-ink-mute font-bold">Lade Kunden…</span>
    </div>
  </div>
  <div id="emptyMsg" class="hidden py-12">
    <div class="flex flex-col items-center justify-center gap-3 text-center">
      <span class="text-[36px]" aria-hidden="true">👥</span>
      <span class="text-[14px] font-extrabold text-ink">Noch keine Kunden</span>
      <span class="text-[12px] text-ink-mute max-w-[360px]">Leg deinen ersten Kunden an — er bekommt einen eigenen Raum mit Brand Identity, Shooting Check, Creator Guide und mehr.</span>
      <button
        type="button"
        id="emptyNewBtn"
        class="mt-2 px-[18px] py-[10px] rounded-full bg-brand text-white text-[12px] font-bold cursor-pointer hover:bg-brand-dark"
      >➕ Ersten Kunden anlegen</button>
    </div>
  </div>

  <!-- "Keine Treffer" — sichtbar wenn Suche nichts findet -->
  <div id="noMatchMsg" class="hidden py-10">
    <div class="flex flex-col items-center justify-center gap-2 text-center">
      <span class="text-[28px]" aria-hidden="true">🔍</span>
      <span class="text-[13px] font-extrabold text-ink">Keine Treffer für „<span id="noMatchQuery"></span>"</span>
      <span class="text-[11px] text-ink-mute">Anderer Filter oder Schreibweise probieren.</span>
    </div>
  </div>

  <!-- Result-Counter — sichtbar wenn Suche aktiv und Treffer vorhanden -->
  <div id="resultCount" class="hidden text-[11px] text-ink-mute mb-2 font-medium" aria-live="polite"></div>

  <div class="flex flex-col gap-[7px]" id="customerList"></div>
</AppLayout>

<script is:inline>
  (function () {
    var listEl = document.getElementById("customerList");
    var loadingEl = document.getElementById("loadingMsg");
    var emptyEl = document.getElementById("emptyMsg");
    var noMatchEl = document.getElementById("noMatchMsg");
    var noMatchQueryEl = document.getElementById("noMatchQuery");
    var resultCountEl = document.getElementById("resultCount");
    var searchInput = document.getElementById("searchInput");
    var searchClear = document.getElementById("searchClear");
    var pills = document.querySelectorAll(".filter-pill");
    var newBtn = document.getElementById("newCustomerBtn");
    var currentFilter = "all";
    var searchQuery = "";
    var lastState = { list: [] };

    // Initial-Query aus URL (?q=...) übernehmen
    (function initFromUrl(){
      var q = new URLSearchParams(location.search).get("q");
      if (q) {
        searchQuery = q.trim().toLowerCase();
        searchInput.value = q;
        searchClear.classList.remove("hidden");
      }
    })();

    function syncUrl() {
      var url = new URL(location.href);
      if (searchQuery) url.searchParams.set("q", searchQuery);
      else url.searchParams.delete("q");
      // replaceState statt pushState — kein Browser-History-Müll bei jedem Tippen
      history.replaceState({}, "", url.toString());
    }

    function matchesSearch(c) {
      if (!searchQuery) return true;
      var hay = ((c.name || "") + " " + (c.room || "") + " " + (c.id || "")).toLowerCase();
      return hay.indexOf(searchQuery) !== -1;
    }

    function progressOf(c) {
      var keys = ["agP", "biP", "shP", "crP", "dP", "mkP"];
      var sum = 0;
      keys.forEach(function (k) { sum += c[k] || 0; });
      return Math.round(sum / keys.length);
    }

    function render() {
      var ui = window.appUI;
      var me = (window.ME && window.ME.uid) || null;
      var allCount = lastState.list.length;
      // Erst Filter (all/mine/active/archived), dann Suche
      var filtered = lastState.list.filter(function (c) {
        if (currentFilter === "mine") return c.createdBy === me;
        if (currentFilter === "active") return !c.arch;
        if (currentFilter === "archived") return c.arch;
        return true;
      });
      var rows = filtered.filter(matchesSearch);

      loadingEl.classList.add("hidden");

      // Drei mögliche Zustände:
      //  a) Liste leer + keine Suche = "Noch keine Kunden"
      //  b) Suche aktiv aber keine Treffer = "Keine Treffer"
      //  c) Treffer vorhanden = Liste rendern + (bei Suche) Counter
      var hasResults = rows.length > 0;
      var hasSearch = !!searchQuery;
      emptyEl.classList.toggle("hidden", hasResults || hasSearch || allCount > 0);
      noMatchEl.classList.toggle("hidden", hasResults || !hasSearch);
      if (hasSearch && !hasResults) {
        noMatchQueryEl.textContent = searchInput.value;
      }
      if (hasSearch && hasResults) {
        resultCountEl.classList.remove("hidden");
        resultCountEl.textContent = rows.length + " von " + filtered.length + " Kunden";
      } else {
        resultCountEl.classList.add("hidden");
      }
      listEl.innerHTML = rows
        .map(function (c) {
          var pct = progressOf(c);
          var nameSafe = ui.escapeHtml(c.name || "Unbenannt");
          var roomSafe = ui.escapeHtml(c.room || "");
          var initialsSafe = ui.escapeHtml(ui.initials(c.name));
          var idSafe = ui.escapeHtml(c.id);
          var archBadge = c.arch
            ? ' <span class="text-[9px] font-bold px-[7px] py-[2px] rounded-full bg-[#f5f5f5] text-ink-mute ml-1">Archiv</span>'
            : "";
          return (
            '<div class="bg-card border-[0.5px] border-line rounded-[10px] px-4 py-3 flex items-center gap-3 hover:border-brand-border" data-id="' +
            idSafe + '">' +
            '<span class="w-2 h-2 rounded-full shrink-0 ' +
            (c.arch ? "bg-line" : "bg-success") + '"></span>' +
            '<a href="/customer?id=' + encodeURIComponent(c.id) +
            '" class="w-[34px] h-[34px] rounded-full bg-brand-dim text-brand text-[12px] font-bold flex items-center justify-center shrink-0 no-underline">' +
            initialsSafe + "</a>" +
            '<a href="/customer?id=' + encodeURIComponent(c.id) +
            '" class="flex-1 min-w-0 no-underline">' +
            '<div class="text-[13px] font-bold text-ink truncate">' +
            nameSafe + archBadge + "</div>" +
            '<div class="text-[11px] text-ink-mute truncate mt-[1px]">Raum ' +
            roomSafe + " · " +
            ui.escapeHtml(ui.fmtAgo(c.lastActive || c.created)) +
            "</div></a>" +
            '<div class="w-[80px] shrink-0">' +
            '<div class="h-[3px] bg-[#eee] rounded-sm overflow-hidden"><div class="h-full bg-brand rounded-sm" style="width:' +
            pct + '%"></div></div>' +
            '<div class="text-[10px] text-ink-mute mt-[3px] text-right">' +
            pct + "%</div></div>" +
            '<div class="flex gap-1 shrink-0 ml-2">' +
            '<button type="button" data-act="rename" data-id="' + idSafe +
            '" class="text-[11px] text-ink-mute hover:text-brand bg-transparent border-0 cursor-pointer px-1" title="Umbenennen">✎</button>' +
            '<button type="button" data-act="archive" data-id="' + idSafe +
            '" class="text-[11px] text-ink-mute hover:text-brand bg-transparent border-0 cursor-pointer px-1" title="' +
            (c.arch ? "Wiederherstellen" : "Archivieren") + '">' +
            (c.arch ? "↺" : "🗄") + "</button>" +
            '<button type="button" data-act="delete" data-id="' + idSafe +
            '" class="text-[11px] text-ink-mute hover:text-brand bg-transparent border-0 cursor-pointer px-1" title="Löschen">✕</button>' +
            "</div></div>"
          );
        })
        .join("");

      listEl.querySelectorAll("[data-act]").forEach(function (b) {
        b.addEventListener("click", function (e) {
          e.preventDefault();
          e.stopPropagation();
          var id = b.dataset.id;
          var c = lastState.list.find(function (x) { return x.id === id; });
          if (!c) return;
          if (b.dataset.act === "rename") {
            ui.prompt({
              title: "Kunde umbenennen",
              description: "Neuer Name für „" + (c.name || "?") + "“",
              value: c.name || "",
              placeholder: "Name",
            }).then(function (val) {
              if (val && val.trim())
                window.fb
                  .ref("workspace/customers/" + id + "/name")
                  .set(val.trim())
                  .catch(function (e) { ui.toast("Fehler: " + e.code); });
            });
          } else if (b.dataset.act === "archive") {
            window.fb
              .ref("workspace/customers/" + id + "/arch")
              .set(!c.arch)
              .catch(function (e) { ui.toast("Fehler: " + e.code); });
          } else if (b.dataset.act === "delete") {
            ui.confirm({
              title: "Kunde löschen?",
              description:
                "„" + (c.name || "?") +
                "“ wird aus der Liste entfernt UND der Portal-Link wird gesperrt. Der Kunde kann den Link danach nicht mehr öffnen. Tool-Daten im Raum bleiben für dich als Backup erhalten.",
              okLabel: "Löschen",
            }).then(function (ok) {
              if (!ok) return;
              Promise.all([
                window.fb.ref("rooms/" + c.room + "/_closed").set({
                  ts: window.fb.ts(),
                  reason: "customer-deleted",
                }),
                window.fb.ref("workspace/customers/" + id).remove(),
              ]).catch(function (e) { ui.toast("Fehler: " + (e.code || e.message)); });
            });
          }
        });
      });
    }

    var renderThrottled = window.appUI.throttle(render, 250);

    pills.forEach(function (p) {
      p.addEventListener("click", function () {
        currentFilter = p.dataset.filter;
        window.appUI.setActiveTab(
          pills,
          p,
          "bg-brand border-brand text-white",
          "border-line text-ink-mute bg-transparent"
        );
        render();
      });
    });

    // Search-Handler
    function applySearch() {
      searchQuery = searchInput.value.trim().toLowerCase();
      searchClear.classList.toggle("hidden", !searchInput.value);
      syncUrl();
      render();
    }
    searchInput.addEventListener("input", applySearch);
    searchInput.addEventListener("keydown", function (e) {
      if (e.key === "Escape") {
        searchInput.value = "";
        applySearch();
        searchInput.blur();
      } else if (e.key === "Enter") {
        // Erstes Resultat öffnen falls vorhanden
        var firstLink = listEl.querySelector('a[href^="/customer?id="]');
        if (firstLink) {
          location.href = firstLink.getAttribute("href");
        }
      }
    });
    searchClear.addEventListener("click", function () {
      searchInput.value = "";
      applySearch();
      searchInput.focus();
    });
    // "/" als globaler Shortcut um die Suche zu fokussieren
    document.addEventListener("keydown", function (e) {
      if (e.key === "/" && document.activeElement && document.activeElement.tagName !== "INPUT" && document.activeElement.tagName !== "TEXTAREA") {
        e.preventDefault();
        searchInput.focus();
        searchInput.select();
      }
    });

    function openNewCustomer() {
      if (!window.ME || !window.ME.uid) {
        window.appUI.toast("Bitte erst einloggen — bin noch nicht bereit.");
        return;
      }
      window.appUI
        .prompt({
          title: "Neuer Kunde",
          description: "Wie heißt der Kunde?",
          placeholder: "z. B. Maria Kaufmann",
          okLabel: "Anlegen",
        })
        .then(function (name) {
          if (!name) return;
          var id =
            Date.now().toString(36) + Math.random().toString(36).slice(2, 6);
          var room = window.appUI.genRoom();
          var rec = {
            id: id,
            name: name,
            room: room,
            arch: false,
            created: window.fb.ts(),
            lastActive: window.fb.ts(),
            agP: 0,
            biP: 0,
            shP: 0,
            crP: 0,
            dP: 0,
            mkP: 0,
            createdBy: window.ME.uid,
          };
          var path = "workspace/customers/" + id;
          window.fb
            .ref(path)
            .set(rec)
            .then(function () {
              return window.fb.ref(path).once("value");
            })
            .then(function (snap) {
              var v = snap.val();
              if (!v || v.id !== id) {
                throw new Error(
                  "Schreibung nicht persistiert — Readback leer."
                );
              }
              window.appUI.toast("✓ Kunde gespeichert (Raum " + room + ")");
              setTimeout(function () {
                location.href = "/customer?id=" + encodeURIComponent(id);
              }, 350);
            })
            .catch(function (e) {
              console.error("[customer] WRITE FAILED:", e);
              window.appUI.toast(
                "Fehler beim Speichern: " + (e.code || e.message)
              );
            });
        });
    }

    function gateNewBtn(disabled) {
      newBtn.disabled = disabled;
      newBtn.style.opacity = disabled ? "0.5" : "";
      newBtn.style.cursor = disabled ? "not-allowed" : "";
      newBtn.title = disabled ? "Warte auf Anmeldung…" : "";
    }
    gateNewBtn(true);
    newBtn.addEventListener("click", openNewCustomer);
    var emptyNewBtn = document.getElementById("emptyNewBtn");
    if (emptyNewBtn) emptyNewBtn.addEventListener("click", openNewCustomer);

    window.appUI.onAuth(function () {
      gateNewBtn(false);
      window.appUI.subscribeCustomers(function (state) {
        lastState = state;
        renderThrottled();
      });
      if (new URLSearchParams(location.search).get("new") === "1") {
        openNewCustomer();
      }
    });

    // ── Globaler Backup-Export ────────────────────────────────
    var exportBtn = document.getElementById("exportBtn");
    var exportLabel = exportBtn ? exportBtn.textContent : "";
    function setExportState(text, busy) {
      if (!exportBtn) return;
      exportBtn.textContent = text;
      exportBtn.disabled = !!busy;
      exportBtn.style.opacity = busy ? "0.6" : "";
      exportBtn.style.cursor = busy ? "wait" : "pointer";
    }
    if (exportBtn) {
      exportBtn.addEventListener("click", function () {
        var ui = window.appUI;
        if (!lastState || !lastState.list) {
          ui.toast("Noch keine Daten geladen — kurz warten");
          return;
        }
        ui.confirm({
          title: "Backup erstellen?",
          description:
            "Lädt " + lastState.list.length + " Kunden + alle ihre Tool-Räume als " +
            "JSON-Datei herunter. Bei vielen Bildern kann das einige Sekunden dauern.",
          okLabel: "Download starten",
        }).then(function (ok) {
          if (!ok) return;
          var customers = lastState.list.slice();
          setExportState("⏳ Lade " + customers.length + " Räume…", true);

          // Fetch all rooms in parallel
          Promise.all(customers.map(function (c) {
            if (!c.room) return Promise.resolve(null);
            return window.fb.ref("rooms/" + c.room).once("value")
              .then(function (s) { return s.val(); })
              .catch(function () { return null; });
          })).then(function (roomDatas) {
            var bundle = {
              exportedAt: new Date().toISOString(),
              workspace: "unsigned-workspace",
              customerCount: customers.length,
              customers: customers.map(function (c, i) {
                return {
                  customer: c,
                  room: { id: c.room || null, data: roomDatas[i] || null },
                };
              }),
            };
            var json = JSON.stringify(bundle, null, 2);
            var blob = new Blob([json], { type: "application/json" });
            var url = URL.createObjectURL(blob);
            var a = document.createElement("a");
            a.href = url;
            var d = new Date().toISOString().slice(0, 10);
            var sizeMb = (blob.size / 1024 / 1024).toFixed(1);
            a.download = "unsigned-backup-" + d + ".json";
            document.body.appendChild(a);
            a.click();
            a.remove();
            URL.revokeObjectURL(url);
            setExportState(exportLabel, false);
            ui.toast("Backup heruntergeladen — " + sizeMb + " MB ✓");
          }).catch(function (err) {
            setExportState(exportLabel, false);
            ui.toast("Backup fehlgeschlagen: " + (err.code || err.message));
          });
        });
      });
    }
  })();
</script>
