---
import BaseLayout from "./BaseLayout.astro";
import Sidebar from "../components/Sidebar.astro";
import AuthGuard from "../components/AuthGuard.astro";
import AppHelpers from "../components/AppHelpers.astro";

interface Props {
  title: string;
  active: string;
}

const { title, active } = Astro.props;
---

<BaseLayout title={`${title} · Unsigned Workspace`}>
  <AuthGuard />
  <AppHelpers />
  <div class="flex h-screen w-screen overflow-hidden">
    <Sidebar active={active} />
    <main class="flex-1 flex flex-col overflow-hidden min-w-0">
      <header
        class="bg-card border-b-[0.5px] border-line px-[22px] py-3 flex items-center gap-[10px] shrink-0"
      >
        <h1 class="text-[15px] font-extrabold text-ink flex-1">{title}</h1>
      </header>
      <div class="flex-1 overflow-y-auto px-6 py-[22px]">
        <slot />
      </div>
    </main>
  </div>
</BaseLayout>
