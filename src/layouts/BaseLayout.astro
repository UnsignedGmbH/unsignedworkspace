---
import "../styles/global.css";

interface Props {
  title?: string;
}

const { title = "Unsigned Workspace" } = Astro.props;
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1.0,viewport-fit=cover" />
    <link rel="icon" type="image/png" href="/brand/v-dark.png" />
    <!-- PWA: Web Manifest + Theme + iOS-spezifische Tags fuer "Zum Home-Bildschirm hinzufuegen" -->
    <link rel="manifest" href="/manifest.webmanifest" />
    <meta name="theme-color" content="#c13030" />
    <link rel="apple-touch-icon" href="/brand/v-dark.png" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="default" />
    <meta name="apple-mobile-web-app-title" content="Unsigned" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <!-- Firebase: Preconnect zu allen drei Hosts (gstatic für SDK, identitytoolkit
         für Auth, RTDB für Daten). Spart DNS + TLS-Handshake = ~200-500ms auf Mobile. -->
    <link rel="preconnect" href="https://www.gstatic.com" crossorigin />
    <link rel="preconnect" href="https://identitytoolkit.googleapis.com" crossorigin />
    <link rel="preconnect" href="https://unsignedworkspace-default-rtdb.europe-west1.firebasedatabase.app" crossorigin />
    <!-- Firebase-SDK-Scripts mit höchster Priorität vorab laden (parallel zu HTML-Parse) -->
    <link rel="preload" as="script" href="https://www.gstatic.com/firebasejs/9.22.0/firebase-app-compat.js" />
    <link rel="preload" as="script" href="https://www.gstatic.com/firebasejs/9.22.0/firebase-auth-compat.js" />
    <link rel="preload" as="script" href="https://www.gstatic.com/firebasejs/9.22.0/firebase-database-compat.js" />
    <link
      href="https://fonts.googleapis.com/css2?family=Montserrat:ital,wght@0,400;0,500;0,600;0,700;0,800;0,900;1,700;1,900&family=Dancing+Script:wght@700&display=swap"
      rel="stylesheet"
    />
    <script is:inline src="https://www.gstatic.com/firebasejs/9.22.0/firebase-app-compat.js"></script>
    <script is:inline src="https://www.gstatic.com/firebasejs/9.22.0/firebase-auth-compat.js"></script>
    <script is:inline src="https://www.gstatic.com/firebasejs/9.22.0/firebase-database-compat.js"></script>
    <script is:inline>
      window.FB_CFG = {
        apiKey: "AIzaSyDJqdh3apGM4fcsjRYI7vZ4VrT1_A6L92U",
        authDomain: "unsignedworkspace.firebaseapp.com",
        databaseURL:
          "https://unsignedworkspace-default-rtdb.europe-west1.firebasedatabase.app",
        projectId: "unsignedworkspace",
        storageBucket: "unsignedworkspace.firebasestorage.app",
        messagingSenderId: "144491079509",
        appId: "1:144491079509:web:c7dcc1c14b8daf404231dc",
      };
      if (window.firebase && !window.firebase.apps.length) {
        window.firebase.initializeApp(window.FB_CFG);
        // Persist auth across reloads (LOCAL = IndexedDB, default but explicit).
        try {
          window.firebase
            .auth()
            .setPersistence(window.firebase.auth.Auth.Persistence.LOCAL)
            .catch(function (e) {
              console.error("[fb] setPersistence failed:", e);
            });
        } catch (e) {
          console.error("[fb] setPersistence threw:", e);
        }
      }
      window.fb = {
        auth: () => window.firebase.auth(),
        db: () => window.firebase.database(),
        ref: (path) => window.firebase.database().ref(path),
        ts: () => Date.now(),
      };

      // ── Toast notifications (global) ──
      window.toast = function (msg, kind, opts) {
        kind = kind || "info";
        opts = opts || {};
        var host = document.getElementById("uw-toast-host");
        if (!host) {
          host = document.createElement("div");
          host.id = "uw-toast-host";
          host.style.cssText =
            "position:fixed;bottom:16px;right:16px;z-index:9999;display:flex;flex-direction:column;gap:8px;max-width:340px;pointer-events:none;font-family:var(--font-sans,system-ui)";
          document.body.appendChild(host);
        }
        var bg = kind === "error" ? "#c13030" : kind === "success" ? "#1d9e75" : "#185fa5";
        var t = document.createElement("div");
        t.setAttribute("role", kind === "error" ? "alert" : "status");
        t.style.cssText =
          "pointer-events:auto;background:" + bg +
          ";color:#fff;padding:10px 14px;border-radius:10px;font-size:13px;font-weight:600;box-shadow:0 8px 24px rgba(0,0,0,0.18);opacity:0;transform:translateY(8px);transition:opacity .2s,transform .2s;display:flex;align-items:center;gap:10px";
        var span = document.createElement("span");
        span.textContent = String(msg);
        span.style.flex = "1";
        var close = document.createElement("button");
        close.textContent = "✕";
        close.setAttribute("aria-label", "Schließen");
        close.style.cssText =
          "background:transparent;border:0;color:#fff;font-size:14px;cursor:pointer;padding:0 2px;opacity:.85";
        t.appendChild(span);
        t.appendChild(close);
        host.appendChild(t);
        requestAnimationFrame(function () {
          t.style.opacity = "1";
          t.style.transform = "translateY(0)";
        });
        var ttl = opts.ttl != null ? opts.ttl : kind === "error" ? 6000 : 3000;
        var timer = ttl > 0 ? setTimeout(dismiss, ttl) : null;
        function dismiss() {
          if (timer) clearTimeout(timer);
          t.style.opacity = "0";
          t.style.transform = "translateY(8px)";
          setTimeout(function () {
            if (t.parentNode) t.parentNode.removeChild(t);
          }, 220);
        }
        close.addEventListener("click", dismiss);
        return dismiss;
      };

      // ── safeWrite helpers ──
      // Wraps Firebase RTDB writes with .catch() + visible toast + 1 retry on transient errors.
      // Always returns a Promise. Errors are surfaced to user but the promise still rejects so
      // callers that already chain .then() get the failure too.
      (function () {
        var TRANSIENT_RE = /(network|disconnect|timeout|temporarily|unavailable)/i;
        function attempt(refPath, op, value, retried) {
          var ref = typeof refPath === "string" ? window.fb.ref(refPath) : refPath;
          var p =
            op === "set"
              ? ref.set(value)
              : op === "update"
                ? ref.update(value)
                : op === "remove"
                  ? ref.remove()
                  : op === "push"
                    ? ref.push(value)
                    : Promise.reject(new Error("safeWrite: unknown op " + op));
          return p.catch(function (err) {
            var msg = (err && err.message) || String(err);
            if (!retried && TRANSIENT_RE.test(msg)) {
              return attempt(ref, op, value, true);
            }
            try {
              window.toast(
                "Speichern fehlgeschlagen: " + msg.slice(0, 120),
                "error"
              );
            } catch (_) {}
            console.error("[safeWrite]", op, ref.toString(), err);
            throw err;
          });
        }
        window.fb.safeSet = function (refPath, value) {
          return attempt(refPath, "set", value);
        };
        window.fb.safeUpdate = function (refPath, value) {
          return attempt(refPath, "update", value);
        };
        window.fb.safeRemove = function (refPath) {
          return attempt(refPath, "remove");
        };
        window.fb.safePush = function (refPath, value) {
          return attempt(refPath, "push", value);
        };
      })();

      // ── Online/Offline-Banner ──
      // Hört passiv auf Connection-Events, schreibt selbst nichts.
      // Banner wird NUR gezeigt wenn länger als 2s disconnect (vermeidet Flackern
      // bei kurzen Aussetzern). Firebase queued Writes lokal weiter; Banner ist
      // nur visuelles Signal "deine Änderungen sind gerade nicht synchronisiert".
      (function () {
        // 5s gibt Firebase auf Mobile-Funk genug Zeit zum Re-Connect ohne
        // dass kurze Aussetzer als "Offline" an den User durchschlagen.
        var DEBOUNCE_MS = 5000;
        var fbConnected = true;     // Default: assume connected bis .info/connected feuert
        var navOnline = typeof navigator !== "undefined" ? navigator.onLine : true;
        var debounceTimer = null;
        var bannerEl = null;

        function ensureBanner() {
          if (bannerEl) return bannerEl;
          bannerEl = document.createElement("div");
          bannerEl.id = "uw-offline-banner";
          bannerEl.setAttribute("role", "status");
          bannerEl.setAttribute("aria-live", "polite");
          bannerEl.style.cssText =
            "position:fixed;top:0;left:0;right:0;z-index:9998;background:#c13030;color:#fff;" +
            "padding:8px 14px;text-align:center;font:600 12px Montserrat,system-ui,sans-serif;" +
            "box-shadow:0 2px 8px rgba(0,0,0,0.15);transform:translateY(-100%);" +
            "transition:transform .25s var(--ease-out-quart, ease-out);pointer-events:none;";
          var icon = document.createElement("span");
          icon.style.marginRight = "6px";
          icon.textContent = "⚠";
          bannerEl.appendChild(icon);
          bannerEl.appendChild(
            document.createTextNode(
              "Offline — Änderungen werden gespeichert sobald die Verbindung zurück ist"
            )
          );
          document.body.appendChild(bannerEl);
          return bannerEl;
        }
        function applyState() {
          var online = fbConnected && navOnline;
          if (online) {
            if (bannerEl) bannerEl.style.transform = "translateY(-100%)";
          } else {
            ensureBanner().style.transform = "translateY(0)";
          }
        }
        function scheduleApply() {
          if (debounceTimer) clearTimeout(debounceTimer);
          var online = fbConnected && navOnline;
          if (online) {
            // Online sofort verstecken, kein Debounce
            applyState();
          } else {
            // Offline erst nach Debounce zeigen
            debounceTimer = setTimeout(applyState, DEBOUNCE_MS);
          }
        }

        if (typeof window !== "undefined") {
          window.addEventListener("online", function () {
            navOnline = true;
            scheduleApply();
          });
          window.addEventListener("offline", function () {
            navOnline = false;
            scheduleApply();
          });
        }

        // Firebase .info/connected sobald Firebase ready ist
        function attachFirebaseConnectionWatch() {
          if (!window.firebase || !window.firebase.database) return false;
          try {
            window.firebase.database().ref(".info/connected").on("value", function (snap) {
              fbConnected = snap.val() === true;
              scheduleApply();
            });
            return true;
          } catch (e) { return false; }
        }
        if (!attachFirebaseConnectionWatch()) {
          var attempts = 0;
          var poll = setInterval(function () {
            if (attachFirebaseConnectionWatch() || ++attempts > 20) clearInterval(poll);
          }, 250);
        }
      })();

      try {
        var savedAccent = localStorage.getItem("uw.accent");
        if (savedAccent) {
          document.documentElement.style.setProperty(
            "--color-brand",
            savedAccent
          );
        }
      } catch (e) {}
    </script>
  </head>
  <body>
    <slot />
  </body>
</html>
