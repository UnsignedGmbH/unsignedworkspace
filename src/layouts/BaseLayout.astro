---
import "../styles/global.css";

interface Props {
  title?: string;
}

const { title = "Unsigned Workspace" } = Astro.props;
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1.0,viewport-fit=cover" />
    <link rel="icon" type="image/png" href="/brand/v-dark.png" />
    <!-- PWA: Web Manifest + Theme + iOS-spezifische Tags fuer "Zum Home-Bildschirm hinzufuegen" -->
    <link rel="manifest" href="/manifest.webmanifest" />
    <meta name="theme-color" content="#c13030" />
    <link rel="apple-touch-icon" href="/brand/v-dark.png" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="default" />
    <meta name="apple-mobile-web-app-title" content="Unsigned" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <!-- Firebase: Preconnect zu allen drei Hosts (gstatic für SDK, identitytoolkit
         für Auth, RTDB für Daten). Spart DNS + TLS-Handshake = ~200-500ms auf Mobile. -->
    <link rel="preconnect" href="https://www.gstatic.com" crossorigin />
    <link rel="preconnect" href="https://identitytoolkit.googleapis.com" crossorigin />
    <link rel="preconnect" href="https://unsignedworkspace-default-rtdb.europe-west1.firebasedatabase.app" crossorigin />
    <!-- Firebase-SDK-Scripts mit höchster Priorität vorab laden (parallel zu HTML-Parse) -->
    <link rel="preload" as="script" href="https://www.gstatic.com/firebasejs/9.22.0/firebase-app-compat.js" />
    <link rel="preload" as="script" href="https://www.gstatic.com/firebasejs/9.22.0/firebase-auth-compat.js" />
    <link rel="preload" as="script" href="https://www.gstatic.com/firebasejs/9.22.0/firebase-database-compat.js" />
    <link
      href="https://fonts.googleapis.com/css2?family=Montserrat:ital,wght@0,400;0,500;0,600;0,700;0,800;0,900;1,700;1,900&family=Dancing+Script:wght@700&display=swap"
      rel="stylesheet"
    />
    <script is:inline src="https://www.gstatic.com/firebasejs/9.22.0/firebase-app-compat.js"></script>
    <script is:inline src="https://www.gstatic.com/firebasejs/9.22.0/firebase-auth-compat.js"></script>
    <script is:inline src="https://www.gstatic.com/firebasejs/9.22.0/firebase-database-compat.js"></script>
    <script is:inline>
      window.FB_CFG = {
        apiKey: "AIzaSyDJqdh3apGM4fcsjRYI7vZ4VrT1_A6L92U",
        authDomain: "unsignedworkspace.firebaseapp.com",
        databaseURL:
          "https://unsignedworkspace-default-rtdb.europe-west1.firebasedatabase.app",
        projectId: "unsignedworkspace",
        storageBucket: "unsignedworkspace.firebasestorage.app",
        messagingSenderId: "144491079509",
        appId: "1:144491079509:web:c7dcc1c14b8daf404231dc",
      };
      if (window.firebase && !window.firebase.apps.length) {
        window.firebase.initializeApp(window.FB_CFG);
        // Persist auth across reloads (LOCAL = IndexedDB, default but explicit).
        try {
          window.firebase
            .auth()
            .setPersistence(window.firebase.auth.Auth.Persistence.LOCAL)
            .catch(function (e) {
              console.error("[fb] setPersistence failed:", e);
            });
        } catch (e) {
          console.error("[fb] setPersistence threw:", e);
        }
      }
      window.fb = {
        auth: () => window.firebase.auth(),
        db: () => window.firebase.database(),
        ref: (path) => window.firebase.database().ref(path),
        ts: () => Date.now(),
      };

      // ── Toast notifications (global) ──
      window.toast = function (msg, kind, opts) {
        kind = kind || "info";
        opts = opts || {};
        var host = document.getElementById("uw-toast-host");
        if (!host) {
          host = document.createElement("div");
          host.id = "uw-toast-host";
          host.style.cssText =
            "position:fixed;bottom:16px;right:16px;z-index:9999;display:flex;flex-direction:column;gap:8px;max-width:340px;pointer-events:none;font-family:var(--font-sans,system-ui)";
          document.body.appendChild(host);
        }
        var bg = kind === "error" ? "#c13030" : kind === "success" ? "#1d9e75" : "#185fa5";
        var t = document.createElement("div");
        t.setAttribute("role", kind === "error" ? "alert" : "status");
        t.style.cssText =
          "pointer-events:auto;background:" + bg +
          ";color:#fff;padding:10px 14px;border-radius:10px;font-size:13px;font-weight:600;box-shadow:0 8px 24px rgba(0,0,0,0.18);opacity:0;transform:translateY(8px);transition:opacity .2s,transform .2s;display:flex;align-items:center;gap:10px";
        var span = document.createElement("span");
        span.textContent = String(msg);
        span.style.flex = "1";
        var close = document.createElement("button");
        close.textContent = "✕";
        close.setAttribute("aria-label", "Schließen");
        close.style.cssText =
          "background:transparent;border:0;color:#fff;font-size:14px;cursor:pointer;padding:0 2px;opacity:.85";
        t.appendChild(span);
        t.appendChild(close);
        host.appendChild(t);
        requestAnimationFrame(function () {
          t.style.opacity = "1";
          t.style.transform = "translateY(0)";
        });
        var ttl = opts.ttl != null ? opts.ttl : kind === "error" ? 6000 : 3000;
        var timer = ttl > 0 ? setTimeout(dismiss, ttl) : null;
        function dismiss() {
          if (timer) clearTimeout(timer);
          t.style.opacity = "0";
          t.style.transform = "translateY(8px)";
          setTimeout(function () {
            if (t.parentNode) t.parentNode.removeChild(t);
          }, 220);
        }
        close.addEventListener("click", dismiss);
        return dismiss;
      };

      // ── safeWrite helpers ──
      // Wraps Firebase RTDB writes with .catch() + visible toast + 1 retry on transient errors.
      // Always returns a Promise. Errors are surfaced to user but the promise still rejects so
      // callers that already chain .then() get the failure too.
      (function () {
        var TRANSIENT_RE = /(network|disconnect|timeout|temporarily|unavailable)/i;
        function attempt(refPath, op, value, retried) {
          var ref = typeof refPath === "string" ? window.fb.ref(refPath) : refPath;
          var p =
            op === "set"
              ? ref.set(value)
              : op === "update"
                ? ref.update(value)
                : op === "remove"
                  ? ref.remove()
                  : op === "push"
                    ? ref.push(value)
                    : Promise.reject(new Error("safeWrite: unknown op " + op));
          return p.catch(function (err) {
            var msg = (err && err.message) || String(err);
            if (!retried && TRANSIENT_RE.test(msg)) {
              return attempt(ref, op, value, true);
            }
            try {
              window.toast(
                "Speichern fehlgeschlagen: " + msg.slice(0, 120),
                "error"
              );
            } catch (_) {}
            console.error("[safeWrite]", op, ref.toString(), err);
            throw err;
          });
        }
        window.fb.safeSet = function (refPath, value) {
          return attempt(refPath, "set", value);
        };
        window.fb.safeUpdate = function (refPath, value) {
          return attempt(refPath, "update", value);
        };
        window.fb.safeRemove = function (refPath) {
          return attempt(refPath, "remove");
        };
        window.fb.safePush = function (refPath, value) {
          return attempt(refPath, "push", value);
        };
      })();

      // ── Online/Offline-Banner ──
      // Hört passiv auf Connection-Events, schreibt selbst nichts.
      // Banner wird NUR gezeigt wenn länger als 2s disconnect (vermeidet Flackern
      // bei kurzen Aussetzern). Firebase queued Writes lokal weiter; Banner ist
      // nur visuelles Signal "deine Änderungen sind gerade nicht synchronisiert".
      (function () {
        // 5s gibt Firebase auf Mobile-Funk genug Zeit zum Re-Connect ohne
        // dass kurze Aussetzer als "Offline" an den User durchschlagen.
        var DEBOUNCE_MS = 5000;
        var fbConnected = true;     // Default: assume connected bis .info/connected feuert
        var navOnline = typeof navigator !== "undefined" ? navigator.onLine : true;
        var debounceTimer = null;
        var bannerEl = null;

        function ensureBanner() {
          if (bannerEl) return bannerEl;
          bannerEl = document.createElement("div");
          bannerEl.id = "uw-offline-banner";
          bannerEl.setAttribute("role", "status");
          bannerEl.setAttribute("aria-live", "polite");
          bannerEl.style.cssText =
            "position:fixed;top:0;left:0;right:0;z-index:9998;background:#c13030;color:#fff;" +
            "padding:8px 14px;text-align:center;font:600 12px Montserrat,system-ui,sans-serif;" +
            "box-shadow:0 2px 8px rgba(0,0,0,0.15);transform:translateY(-100%);" +
            "transition:transform .25s var(--ease-out-quart, ease-out);pointer-events:none;";
          var icon = document.createElement("span");
          icon.style.marginRight = "6px";
          icon.textContent = "⚠";
          bannerEl.appendChild(icon);
          bannerEl.appendChild(
            document.createTextNode(
              "Offline — Änderungen werden gespeichert sobald die Verbindung zurück ist"
            )
          );
          document.body.appendChild(bannerEl);
          return bannerEl;
        }
        function applyState() {
          var online = fbConnected && navOnline;
          if (online) {
            if (bannerEl) bannerEl.style.transform = "translateY(-100%)";
          } else {
            ensureBanner().style.transform = "translateY(0)";
          }
        }
        function scheduleApply() {
          if (debounceTimer) clearTimeout(debounceTimer);
          var online = fbConnected && navOnline;
          if (online) {
            // Online sofort verstecken, kein Debounce
            applyState();
          } else {
            // Offline erst nach Debounce zeigen
            debounceTimer = setTimeout(applyState, DEBOUNCE_MS);
          }
        }

        if (typeof window !== "undefined") {
          window.addEventListener("online", function () {
            navOnline = true;
            scheduleApply();
          });
          window.addEventListener("offline", function () {
            navOnline = false;
            scheduleApply();
          });
        }

        // Firebase .info/connected sobald Firebase ready ist
        function attachFirebaseConnectionWatch() {
          if (!window.firebase || !window.firebase.database) return false;
          try {
            window.firebase.database().ref(".info/connected").on("value", function (snap) {
              fbConnected = snap.val() === true;
              scheduleApply();
            });
            return true;
          } catch (e) { return false; }
        }
        if (!attachFirebaseConnectionWatch()) {
          var attempts = 0;
          var poll = setInterval(function () {
            if (attachFirebaseConnectionWatch() || ++attempts > 20) clearInterval(poll);
          }, 250);
        }
      })();

      try {
        var savedAccent = localStorage.getItem("uw.accent");
        if (savedAccent) {
          document.documentElement.style.setProperty(
            "--color-brand",
            savedAccent
          );
        }
      } catch (e) {}

      // ── Diagnose-Pille (klein, oben rechts) ─────────────────────────
      // A · D · R Status — Tap = Cache-Reset, Long-Press = Detail-Panel
      // A: Auth   D: Database-Connection   R: Read-Test (team-once)
      (function () {
        if (window.UW_DIAG_DISABLED) return;
        var pill, panel;
        function ensure() {
          if (pill) return pill;
          pill = document.createElement("div");
          pill.id = "uw-diag-pill";
          pill.style.cssText =
            "position:fixed;top:6px;right:6px;z-index:9990;background:rgba(0,0,0,0.75);color:#fff;font:700 9px/1 Montserrat,system-ui,sans-serif;padding:5px 8px;border-radius:8px;display:flex;gap:6px;align-items:center;cursor:pointer;backdrop-filter:blur(6px);user-select:none;";
          pill.title = "Tap = Detail / Long-Press = Cache-Reset";
          pill.innerHTML = '<span id="uw-d-a">A?</span><span style="opacity:0.4">·</span><span id="uw-d-d">D?</span><span style="opacity:0.4">·</span><span id="uw-d-r">R?</span>';
          var pressTimer = null;
          pill.onpointerdown = function () {
            pressTimer = setTimeout(function () {
              pressTimer = null;
              if (!confirm("App-Cache komplett zurücksetzen und neu starten?")) return;
              doReset();
            }, 700);
          };
          pill.onpointerup = pill.onpointercancel = pill.onpointerleave = function () {
            if (pressTimer) { clearTimeout(pressTimer); pressTimer = null; togglePanel(); }
          };
          if (document.body) document.body.appendChild(pill);
          else document.addEventListener("DOMContentLoaded", function () { document.body.appendChild(pill); });
          return pill;
        }
        function ensurePanel() {
          if (panel) return panel;
          panel = document.createElement("div");
          panel.id = "uw-diag-panel";
          panel.style.cssText =
            "position:fixed;top:32px;right:6px;z-index:9991;background:#0e0e0e;color:#fff;font:600 11px/1.4 Montserrat,system-ui,sans-serif;padding:12px 14px;border-radius:10px;max-width:320px;display:none;box-shadow:0 8px 32px rgba(0,0,0,0.4);";
          panel.innerHTML =
            '<div style="font-weight:900;margin-bottom:6px">Diagnose</div>' +
            '<div id="uw-d-detail" style="white-space:pre-wrap;color:#ddd;font:500 10px/1.5 monospace"></div>' +
            '<button id="uw-d-retest" style="margin-top:8px;background:#185fa5;color:#fff;border:0;border-radius:6px;padding:6px 10px;font:700 10px Montserrat;cursor:pointer">Read erneut testen</button>' +
            '<button id="uw-d-reset" style="margin-top:8px;margin-left:6px;background:#c13030;color:#fff;border:0;border-radius:6px;padding:6px 10px;font:700 10px Montserrat;cursor:pointer">Cache reset</button>';
          if (document.body) document.body.appendChild(panel);
          else document.addEventListener("DOMContentLoaded", function () { document.body.appendChild(panel); });
          panel.querySelector("#uw-d-retest").onclick = function () { runReadTest(); };
          panel.querySelector("#uw-d-reset").onclick = function () {
            if (!confirm("App-Cache komplett zurücksetzen und neu starten?")) return;
            doReset();
          };
          return panel;
        }
        function togglePanel() {
          ensurePanel();
          panel.style.display = panel.style.display === "block" ? "none" : "block";
          updateDetail();
        }
        function doReset() {
          try { if (window.firebase) window.firebase.auth().signOut().catch(function () {}); } catch (e) {}
          try { Object.keys(localStorage).forEach(function (k) { if (k.indexOf("uw.") === 0) localStorage.removeItem(k); }); } catch (e) {}
          try { Object.keys(sessionStorage).forEach(function (k) { if (k.indexOf("uw.") === 0) sessionStorage.removeItem(k); }); } catch (e) {}
          if (window.indexedDB && indexedDB.databases) {
            indexedDB.databases().then(function (dbs) {
              Promise.all((dbs || []).map(function (db) {
                return new Promise(function (r) {
                  try { var rq = indexedDB.deleteDatabase(db.name); rq.onsuccess = rq.onerror = rq.onblocked = function () { r(); }; }
                  catch (e) { r(); }
                });
              })).then(function () { location.replace("/"); });
            }).catch(function () { location.replace("/"); });
          } else { location.replace("/"); }
        }
        function setBg(state) {
          var p = ensure();
          if (state === "ok")    p.style.background = "rgba(29,158,117,0.85)";
          else if (state === "warn") p.style.background = "rgba(193,128,48,0.85)";
          else if (state === "err")  p.style.background = "rgba(193,48,48,0.85)";
          else                       p.style.background = "rgba(0,0,0,0.75)";
        }
        function setLabel(id, label) {
          ensure(); var el = document.getElementById(id); if (el) el.textContent = label;
        }

        var state = { auth: "?", uid: null, db: "?", read: "?", readErr: null, readCount: null, lastTokenAge: null };

        function updateDetail() {
          if (!panel) return;
          var d = document.getElementById("uw-d-detail");
          if (!d) return;
          d.textContent =
            "Auth:   " + state.auth + (state.uid ? " (" + state.uid.slice(0, 12) + "…)" : "") + "\n" +
            "DB-WS:  " + state.db + "\n" +
            "Read:   " + state.read + (state.readCount != null ? " (" + state.readCount + " entries)" : "") + (state.readErr ? "\n        ERR: " + state.readErr : "") + "\n" +
            "Token:  " + (state.lastTokenAge != null ? "alter " + state.lastTokenAge + "s" : "—") + "\n" +
            "URL:    " + location.pathname + "\n" +
            "Time:   " + new Date().toLocaleTimeString();
        }

        function recomputeBg() {
          if (state.auth === "✓" && state.db === "✓" && state.read === "✓") setBg("ok");
          else if (state.read === "❌" || (state.auth === "—" && state.db !== "✓")) setBg("err");
          else setBg("warn");
        }

        // Auth-State watchen
        function watchAuth() {
          if (!window.firebase || !window.firebase.auth) return setTimeout(watchAuth, 200);
          window.firebase.auth().onAuthStateChanged(function (u) {
            state.auth = u ? "✓" : "—";
            state.uid = u ? u.uid : null;
            setLabel("uw-d-a", "A" + state.auth);
            recomputeBg();
            updateDetail();
            // Bei Login Read-Test starten
            if (u) {
              setTimeout(runReadTest, 1500);
              // Token-Alter prüfen
              u.getIdTokenResult().then(function (r) {
                if (r && r.issuedAtTime) {
                  state.lastTokenAge = Math.round((Date.now() - new Date(r.issuedAtTime).getTime()) / 1000);
                  updateDetail();
                }
              }).catch(function () {});
            }
          });
        }
        watchAuth();

        // DB-State watchen
        function watchDb() {
          if (!window.firebase || !window.firebase.database) return setTimeout(watchDb, 200);
          window.firebase.database().ref(".info/connected").on("value", function (s) {
            state.db = s.val() === true ? "✓" : "—";
            setLabel("uw-d-d", "D" + state.db);
            recomputeBg();
            updateDetail();
          });
        }
        watchDb();

        // Echter Read-Test: einmalig 'team' lesen, zeigen ob's klappt
        function runReadTest() {
          if (!window.firebase || !window.firebase.database) return;
          state.read = "…";
          state.readErr = null;
          state.readCount = null;
          setLabel("uw-d-r", "R…");
          recomputeBg();
          updateDetail();
          window.firebase.database().ref("team").once("value")
            .then(function (s) {
              state.read = "✓";
              state.readCount = Object.keys(s.val() || {}).length;
              setLabel("uw-d-r", "R✓");
              recomputeBg();
              updateDetail();
            })
            .catch(function (err) {
              state.read = "❌";
              state.readErr = (err && (err.code || err.message)) || "unknown";
              setLabel("uw-d-r", "R!");
              recomputeBg();
              updateDetail();
              console.error("[diag] read test failed:", err);
            });
        }
      })();
    </script>
  </head>
  <body>
    <slot />
  </body>
</html>
